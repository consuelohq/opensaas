{
  "info": {
    "name": "Consuelo API",
    "description": "API test suite for Consuelo — opensaas sales infrastructure platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "javascript",
        "exec": [
          "// Auto-refresh expired access tokens",
          "if (pm.environment.get('access_token') && pm.environment.get('refresh_token')) {",
          "  const expiry = pm.environment.get('token_expiry');",
          "  if (expiry && parseInt(expiry) < Date.now()) {",
          "    console.log('Access token expired, refreshing...');",
          "    const refreshTokenRequest = {",
          "      method: 'POST',",
          "      url: pm.environment.get('base_url') + '/v1/auth/refresh',",
          "      header: {",
          "        'Content-Type': 'application/json',",
          "        'Authorization': 'Bearer ' + pm.environment.get('refresh_token')",
          "      }",
          "    };",
          "    // Note: This is a placeholder - actual refresh needs implementation",
          "    // pm.sendRequest(refreshTokenRequest, (err, res) => {",
          "    //   if (!err && res.json().access_token) {",
          "    //     pm.environment.set('access_token', res.json().access_token);",
          "    //   }",
          "    // });",
          "  }",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://opensaas-production.up.railway.app",
      "type": "default"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "getLoginTokenFromCredentials",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation GetLoginToken($email: String!, $password: String!, $origin: String!) { getLoginTokenFromCredentials(email: $email, password: $password, origin: $origin) { loginToken { token expiresAt } } }",
                "variables": "{\"email\":\"{{test_email}}\",\"password\":\"{{test_password}}\",\"origin\":\"{{base_url}}\"}"
              }
            },
            "url": {
              "raw": "{{base_url}}/metadata",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "metadata"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Should return 200', function() {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "pm.test('Should contain loginToken', function() {",
                  "  const json = pm.response.json();",
                  "  const token = json.data?.getLoginTokenFromCredentials?.loginToken?.token;",
                  "  pm.expect(token).to.be.a('string');",
                  "  pm.environment.set('login_token', token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "getAuthTokensFromLoginToken",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation GetAuthTokens($loginToken: String!, $origin: String!) { getAuthTokensFromLoginToken(loginToken: $loginToken, origin: $origin) { tokens { accessOrWorkspaceAgnosticToken { token expiresAt } refreshToken { token expiresAt } } } }",
                "variables": "{\"loginToken\":\"{{login_token}}\",\"origin\":\"{{base_url}}\"}"
              }
            },
            "url": {
              "raw": "{{base_url}}/metadata",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "metadata"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Should return 200', function() {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "pm.test('Should contain access and refresh tokens', function() {",
                  "  const json = pm.response.json();",
                  "  const tokens = json.data?.getAuthTokensFromLoginToken?.tokens;",
                  "  pm.expect(tokens?.accessOrWorkspaceAgnosticToken?.token).to.be.a('string');",
                  "  pm.expect(tokens?.refreshToken?.token).to.be.a('string');",
                  "  pm.environment.set('access_token', tokens.accessOrWorkspaceAgnosticToken.token);",
                  "  pm.environment.set('refresh_token', tokens.refreshToken.token);",
                  "  pm.environment.set('token_expiry', Date.now() + 30 * 60 * 1000);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "renewToken",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation RenewToken($appToken: String!) { renewToken(appToken: $appToken) { tokens { accessOrWorkspaceAgnosticToken { token expiresAt } refreshToken { token expiresAt } } } }",
                "variables": "{\"appToken\":\"{{refresh_token}}\"}"
              }
            },
            "url": {
              "raw": "{{base_url}}/metadata",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "metadata"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Should return 200', function() {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "pm.test('Should contain new tokens', function() {",
                  "  const json = pm.response.json();",
                  "  const tokens = json.data?.renewToken?.tokens;",
                  "  pm.expect(tokens?.accessOrWorkspaceAgnosticToken?.token).to.be.a('string');",
                  "  pm.expect(tokens?.refreshToken?.token).to.be.a('string');",
                  "  pm.environment.set('access_token', tokens.accessOrWorkspaceAgnosticToken.token);",
                  "  pm.environment.set('refresh_token', tokens.refreshToken.token);",
                  "  pm.environment.set('token_expiry', Date.now() + 30 * 60 * 1000);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
