{
  "name": "@consuelo/chat-bot",
  "version": "0.0.1",
  "description": "discord bot for consuelo using chat SDK",
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npx tsc",
    "dev": "npx tsc --watch",
    "start": "node dist/main.js"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "dependencies": {
    "@consuelo/logger": "workspace:*"
  },
  "peerDependencies": {
    "chat": ">=4.0.0",
    "@chat-adapter/discord": ">=4.0.0",
    "@chat-adapter/slack": ">=4.0.0",
    "@chat-adapter/state-redis": ">=4.0.0",
    "ioredis": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "chat": {
      "optional": true
    },
    "@chat-adapter/discord": {
      "optional": true
    },
    "@chat-adapter/slack": {
      "optional": true
    },
    "@chat-adapter/state-redis": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "chat": "^4.15.0",
    "@chat-adapter/discord": "^4.15.0",
    "@chat-adapter/slack": "^4.15.0",
    "@chat-adapter/state-redis": "^4.15.0"
  }
}
