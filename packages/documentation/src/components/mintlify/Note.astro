---
const { title } = Astro.props;
---

<aside class="mintlify-callout mintlify-callout-note">
  {title && <strong>{title}</strong>}
  <slot />
</aside>

<style>
  .mintlify-callout { border: 1px solid var(--sl-color-gray-5); border-radius: 0.75rem; margin: 1rem 0; padding: 1rem; }
  .mintlify-callout-note { background: var(--sl-color-blue-low); border-color: var(--sl-color-blue); }
  strong { display: block; margin-bottom: 0.35rem; }
</style>
