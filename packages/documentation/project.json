{
  "name": "documentation",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/documentation/src",
  "projectType": "application",
  "tags": ["scope:docs"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/documentation",
        "command": "bun run dev"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "packages/documentation",
        "command": "bun run build"
      }
    },
    "validate": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "packages/documentation",
        "command": "bun run validate"
      }
    },
    "test-translation": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "packages/documentation",
        "command": "bun run test:translation"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/documentation",
        "command": "bun run preview"
      }
    }
  }
}
