[
  {
    "name": "daily-revenue-brief",
    "title": "Daily Revenue Brief",
    "description": "Scaffold runbook that proves get_steering -> call -> Bun runbook -> optional GraphQL proof query -> structured result.",
    "permission": "read",
    "requiresApproval": false,
    "writesRecords": false,
    "externalSideEffects": false,
    "requiredEnv": [
      "CONSUELO_GRAPHQL_URL",
      "CONSUELO_INTERNAL_GRAPHQL_API_KEY"
    ],
    "requiredIntegrations": [
      "consuelo-graphql"
    ],
    "implementation": {
      "script": "runbooks/daily-revenue-brief.ts"
    },
    "inputSchema": {
      "type": "object",
      "additionalProperties": true
    },
    "outputSchema": {
      "type": "object",
      "required": [
        "summary",
        "workspaceStatus",
        "graphqlStatus",
        "nextSteps"
      ]
    }
  }
]
