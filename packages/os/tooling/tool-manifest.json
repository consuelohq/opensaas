[
  {
    "name": "daily-revenue-brief",
    "title": "Daily Revenue Brief",
    "description": "Scaffold skill that proves get_steering -> call -> Bun skill -> optional GraphQL proof query -> structured result.",
    "permission": "read",
    "requiresApproval": false,
    "writesRecords": false,
    "externalSideEffects": false,
    "requiredEnv": [
      "CONSUELO_GRAPHQL_URL",
      "CONSUELO_INTERNAL_GRAPHQL_API_KEY"
    ],
    "requiredIntegrations": [
      "consuelo-graphql"
    ],
    "implementation": {
      "script": "scripts/revenue/daily-revenue-brief.ts"
    },
    "inputSchema": {
      "type": "object",
      "additionalProperties": true
    },
    "outputSchema": {
      "type": "object",
      "required": [
        "summary",
        "workspaceStatus",
        "graphqlStatus",
        "nextSteps"
      ]
    }
  },
  {
    "name": "consuelo-design-landing-page",
    "title": "Consuelo Design Landing Page",
    "description": "Creates a Consuelo Design website workflow draft through the existing design facade, persists a local draft artifact, and approval-gates publishing or customer-facing replacement.",
    "permission": "draft",
    "requiresApproval": false,
    "writesRecords": false,
    "externalSideEffects": false,
    "requiredIntegrations": [
      "consuelo-design"
    ],
    "implementation": {
      "script": "scripts/design/consuelo-design-landing-page.ts"
    },
    "inputSchema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifactTitle": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "campaign": {
          "type": "object",
          "additionalProperties": true
        },
        "sourceContext": {
          "type": "object",
          "additionalProperties": true
        },
        "publish": {
          "type": "boolean"
        },
        "replaceCustomerFacingPage": {
          "type": "boolean"
        }
      }
    },
    "outputSchema": {
      "type": "object",
      "required": [
        "summary",
        "workflow",
        "designSystem",
        "primaryDesignSkill",
        "nextActions"
      ]
    }
  }
]
