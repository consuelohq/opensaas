    "includePrefixes": [
      "context.",
      "fs.",
      "stream."
    ],
    "includeCategories": [],
    "excludeNames": [
      "mac.call",
      "mac.exec",
      "task.call",
      "task.exec",
      "fs.list",
      "fs.write",
      "gh",
      "decideNext",
      "exploit",
      "confidenceScore",
      "confirm",
      "context.list",
      "context.categories",
      "audit",
      "doctor",
      "status",
      "mac.read",
      "mac.write",
      "mac.search",
      "mac.list",
      "mac.port",
      "mac.process"
    ],
    "excludePrefixes": [
      "browser.",
      "office.",
      "design.",
      "linear.",
      "railway.",
      "sentry.",
      "task.",
      "website.",
      "mac."
    ],
    "excludeCategories": [
      "browser",
      "consuelo design",
      "linear",
      "railway",
      "sentry"
    ]
  },
  "workflows": {
    "path": "packages/workspace/tooling/workflows.json"
  }
}
