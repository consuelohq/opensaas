{
  "version": 1,
  "sources": [
    {
      "label": "workspace-tooling",
      "kind": "facade-tool",
      "path": "packages/workspace/tooling/tool-manifest.json"
    }
  ],
  "outputs": {
    "full": "packages/workspace/manifests/tool-manifest.json",
    "core": "packages/workspace/manifests/core-manifest.json",
    "workflows": "packages/workspace/manifests/workflow-bundles.json"
  },
  "core": {
    "includeNames": [
      "checkFiles",
      "code.call",
      "code.run",
      "explore",
      "git.diff",
      "git.status",
      "github",
      "intent",
      "review.run",
      "tmp",
      "tools.search",
      "verify"
