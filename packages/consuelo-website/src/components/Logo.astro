---
type Props = {
  class?: string;
  width?: number;
  height?: number;
};
const { class: className = '', width = 120, height } = Astro.props;
---

<span class:list={['logo', className]}>
  <img src="/images/logo/logo.svg" alt="Consuelo" width={width} height={height} class="logo-light" />
  <img src="/images/logo/logo-white.svg" alt="Consuelo" width={width} height={height} class="logo-dark" />
</span>

<style>
  .logo { display: inline-flex; }
  .logo-dark { display: none; }
  @media (prefers-color-scheme: dark) {
    .logo-light { display: none; }
    .logo-dark { display: block; }
  }
</style>
