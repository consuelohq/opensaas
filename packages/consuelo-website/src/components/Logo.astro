---
type Props = {
  class?: string;
  width?: number;
  height?: number;
};
const { class: className = '', width = 120, height } = Astro.props;
---

<span class:list={['logo', className]}>
  <img src="/images/logo/logo.svg" alt="Consuelo" width={width} height={height} class="logo-img" />
</span>

<style>
  .logo { display: inline-flex; }
  .logo-img {
    filter: invert(0);
    transition: filter 0.2s ease;
  }
  @media (prefers-color-scheme: dark) {
    .logo-img {
      filter: invert(1);
    }
  }
</style>
