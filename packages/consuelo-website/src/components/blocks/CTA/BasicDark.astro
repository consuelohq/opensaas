---
// Basic Dark Call To Action section
// ------------
// Description: A centered call to action section that contains: a title, text, background image, notification and a button.

// Components
// - Layout
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
// - UI
import CTA from '../../ui/CTA.astro'
import Button from '../../ui/Button.astro'
import ChipNotification from '../../ui/ChipNotification.astro'
import { Image } from 'astro:assets'
import Highlight from '../../ui/Highlight.astro'

// Content
import ctaImage from '../../../assets/cta-dark-bg.webp'
import badge from '../../../assets/badge.svg'
---

<Section>
	<Row>
		<Col span="1" />
		<Col span="10">
			<CTA
				title="Start closing more with less tools."
				text="Join insurance teams using Consuelo to replace their entire sales stack. Free CRM forever, $20/seat power dialer, real-time AI coaching."
				mode="dark"
				bg={ctaImage}
			>
				<ChipNotification radius="rounded-full" classes="mb-6 box">
					<span class="hidden md:block">Open Source,</span>
					<Highlight classes="md:ml-2">Free CRM Forever</Highlight>
				</ChipNotification>
				<Button size="lg" style="primary">Get started free</Button>
			</CTA>
		</Col>
		<Col span="1" />
	</Row>
</Section>
