---
// Feature Cards grid Section
// ------------
// Description: A grid of cards with feature information in a 4 column layout.

// Components
// - Layout
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
// - UI
import Card from '../../ui/cards/FeatureCard.astro'

// Content
// - Cards
import feature01 from '../../../assets/cards/feature-01.svg'
import feature02 from '../../../assets/cards/feature-02.svg'
import feature03 from '../../../assets/cards/feature-03.svg'
import feature04 from '../../../assets/cards/feature-04.svg'
import feature05 from '../../../assets/cards/feature-05.svg'
---

<Section id="features">
	<Row>
		<Col span="12" align="center" classes="mb-12 max-w-4xl mx-auto">
			<h2 class="text-pretty">Telecommunication, AI, and <strong>integration</strong> — in one platform</h2>
			<p class="pb-0 text-lg">
				Everything your sales team needs to connect, coach, and close — powered by an open-source
				stack that replaces your $250/seat toolchain.
			</p>
		</Col>
	</Row>
	<Row>
		<Col span="4" classes="md:col-span-4">
			<Card
				title="Power dialer with local presence"
				subtitle="Dial faster with geo-proximity caller ID that matches your prospect's area code. Parallel dialing, warm and cold transfers, and caller ID locking — built in."
				image={feature01}
				link="/features"
			/>
		</Col>
		<Col span="4" classes="md:col-span-4 flex flex-col gap-6">
			<Card
				title="Real-time AI coaching"
				subtitle="Get live guidance during calls — objection handling, talk-track prompts, and sentiment analysis. Post-call scoring helps reps improve every session."
				image={feature02}
				link="/features"
			/>
			<Card
				title="CRM & contact management"
				subtitle="Free built-in CRM with pipeline tracking, CSV import, contact queues, and DNC filtering. No more paying extra for a separate CRM."
				image={feature03}
				link="/features"
			/>
		</Col>
		<Col span="4" classes="md:col-span-4 flex flex-col gap-6">
			<Card
				title="Analytics & performance"
				subtitle="Track call volume, connect rates, talk time, and conversion metrics across your entire team. Spot top performers and coach the rest."
				image={feature04}
				link="/features"
			/>
			<Card
				title="Open source & integrations"
				subtitle="Self-host or use our hosted version. Integrate with GoHighLevel, Twilio, Stripe, and more. Extend anything — it's all open source."
				image={feature05}
				link="/features"
			/>
		</Col>
	</Row>
</Section>
