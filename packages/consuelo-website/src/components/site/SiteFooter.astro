---
import { homeFooterSignup } from '../../data/home-content';
import { siteLinks } from '../../data/site-links';
import { footerLinks } from '../../data/site-navigation';
import LanguageSelector from './LanguageSelector.astro';

type Props = {
  sectionId?: string;
};

const { sectionId } = Astro.props as Props;
---

<section class="launch-section" id={sectionId}>
  <div class="launch-content launch-content--wide launch-footer-signup">
    <div class="launch-footer-signup__intro">
      <p class="launch-eyebrow">{homeFooterSignup.eyebrow}</p>
      <h2>{homeFooterSignup.title}</h2>
      <p class="launch-copy">{homeFooterSignup.intro}</p>
    </div>

    <form class="launch-footer-signup__form" data-newsletter-form>
      <div class="launch-footer-signup__field">
        <input aria-label="Email address" name="email" placeholder="Email address" type="email" />
        <button class="launch-button launch-mono" type="submit">{homeFooterSignup.buttonLabel}</button>
      </div>
    </form>
  </div>
</section>

<footer class="launch-section">
  <div class="launch-footer-links launch-mono">
    {footerLinks.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
  </div>
  <div class="launch-content launch-content--wide launch-footer-meta launch-mono">
    <span>©2026 Consuelo</span>
    <a href="/blog">Blog</a>
    <a href={siteLinks.github} class="desktop-only-link">GitHub</a>
    <a href={siteLinks.privacy}>Privacy</a>
    <a href={siteLinks.terms}>Terms</a>
    <LanguageSelector />
  </div>
</footer>

<script define:vars={{ siteLinks }}>
  const form = document.querySelector('[data-newsletter-form]');
  if (form instanceof HTMLFormElement) {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const input = form.querySelector('input[name="email"]');
      const email = input instanceof HTMLInputElement ? input.value.trim() : '';
      const base = siteLinks.newsletter;
      const separator = base.includes('?') ? '&' : '?';
      const body = email ? 'body=' + encodeURIComponent('newsletter: ' + email) : '';
      window.location.href = body ? base + separator + body : base;
    });
  }
</script>

<style>
  .launch-footer-signup {
    display: grid;
    gap: 1rem;
  }

  .launch-footer-signup__intro {
    display: grid;
    gap: 0.75rem;
    max-width: 28rem;
  }

  .launch-footer-signup h2 {
    margin: 0;
    font-size: clamp(1rem, 0.9rem + 0.3vw, 1.15rem);
    letter-spacing: -0.06em;
    line-height: 1.04;
  }

  .launch-footer-signup__form {
    display: grid;
    max-width: 40rem;
  }

  .launch-footer-signup__field {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    border: 1px solid var(--launch-line);
    background: var(--launch-panel);
  }

  .launch-footer-signup__field input {
    width: 100%;
    min-height: 2.75rem;
    padding: 0 0.95rem;
    background: transparent;
    color: var(--launch-fg);
    border: 0;
  }

  .launch-footer-signup__field .launch-button {
    margin: 0.26rem;
    min-height: 2.15rem;
  }

  .launch-footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }

  .launch-footer-links a,
  .launch-footer-meta a,
  .launch-footer-meta span {
    padding: 0.9rem 0;
    color: var(--launch-muted);
    font-size: 0.82rem;
  }

  .launch-footer-links a {
    display: flex;
    flex: 1 1 20%;
    align-items: center;
    justify-content: center;
    min-height: 4.5rem;
    min-width: 9rem;
    padding: 1rem 1.1rem;
  }

  .launch-footer-links a + a {
    border-left: 1px solid var(--launch-line);
  }

  .launch-footer-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 1.25rem;
    border-top: 1px solid var(--launch-line);
    padding: 0.9rem 0;
    text-align: center;
  }

  @media (min-width: 980px) {
    .launch-footer-signup {
      gap: 1.15rem;
    }

    .launch-footer-links {
      flex-wrap: nowrap;
    }

    .launch-footer-links a {
      min-width: 0;
    }
  }

  @media (max-width: 640px) {
    .launch-footer-signup__field {
      grid-template-columns: minmax(0, 1fr);
    }

    .launch-footer-signup__field .launch-button {
      width: calc(100% - 0.52rem);
    }

    .launch-footer-links a {
      flex-basis: 100%;
      min-width: 0;
      border-left: 0;
    }

    .launch-footer-links a + a {
      border-top: 1px solid var(--launch-line);
    }

    .launch-footer-meta {
      gap: 0.85rem;
    }
  }

  @media (max-width: 640px) {
    .desktop-only-link {
      display: none !important;
    }
  }
</style>
