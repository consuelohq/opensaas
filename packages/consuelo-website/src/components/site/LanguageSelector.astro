---
const languages = [
  { code: 'en', label: 'English' },
  { code: 'zh-CN', label: '简体中文' },
  { code: 'zh-TW', label: '繁體中文' },
  { code: 'ko', label: '한국어' },
  { code: 'de', label: 'Deutsch' },
  { code: 'es', label: 'Español' },
  { code: 'fr', label: 'Français' },
  { code: 'it', label: 'Italiano' },
  { code: 'da', label: 'Dansk' },
  { code: 'ja', label: '日本語' },
  { code: 'pl', label: 'Polski' },
  { code: 'ru', label: 'Русский' },
  { code: 'ar', label: 'العربية' },
  { code: 'no', label: 'Norsk' },
];
---

<div class="language-selector" data-language-selector data-translate-ignore>
  <button
    class="language-selector__button launch-mono"
    type="button"
    aria-haspopup="true"
    aria-expanded="false"
    data-language-trigger
  >
    <span data-language-label>English</span>
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>

  <div class="language-selector__menu launch-mono" data-language-menu>
    {languages.map((language) => (
      <button class="language-selector__option" type="button" data-language-code={language.code}>
        {language.label}
      </button>
    ))}
  </div>
</div>

<script>
  type TranslateAttributeName = 'placeholder' | 'aria-label' | 'title';

  type TranslateTextTarget = {
    kind: 'text';
    node: Text;
    originalText: string;
  };

  type TranslateAttributeTarget = {
    kind: 'attribute';
    element: HTMLElement;
    attributeName: TranslateAttributeName;
    originalText: string;
  };

  type TranslateTarget = TranslateTextTarget | TranslateAttributeTarget;

  type CachedAttributes = Partial<Record<TranslateAttributeName, string>>;

  type TranslateWindow = Window & {
    __consueloTranslateTextCache?: WeakMap<Text, string>;
    __consueloTranslateAttributeCache?: WeakMap<HTMLElement, CachedAttributes>;
    __consueloTranslationCache?: Record<string, string>;
  };

  const STORAGE_KEY = 'consuelo-language';
  const TRANSLATION_CACHE_KEY = 'consuelo-language-cache-v1';
  const GOOGLE_TRANSLATE_ENDPOINT = 'https://translate.googleapis.com/translate_a/single';
  const MAX_CACHED_TRANSLATIONS = 1500;
  const MAX_BATCH_CHARACTERS = 3500;
  const SPLIT_TOKEN = '[[[consuelo-split-9b1c]]]';
  const IGNORED_TAGS = new Set(['CODE', 'NOSCRIPT', 'PRE', 'SCRIPT', 'STYLE', 'TEXTAREA']);
  const translateWindow = window as TranslateWindow;
  const textCache =
    translateWindow.__consueloTranslateTextCache ?? new WeakMap<Text, string>();
  const attributeCache =
    translateWindow.__consueloTranslateAttributeCache ??
    new WeakMap<HTMLElement, CachedAttributes>();

  translateWindow.__consueloTranslateTextCache = textCache;
  translateWindow.__consueloTranslateAttributeCache = attributeCache;

  const readTranslationCache = (): Record<string, string> => {
    if (translateWindow.__consueloTranslationCache) {
      return translateWindow.__consueloTranslationCache;
    }

    try {
      const rawCache = window.localStorage.getItem(TRANSLATION_CACHE_KEY);

      if (!rawCache) {
        translateWindow.__consueloTranslationCache = {};

        return translateWindow.__consueloTranslationCache;
      }

      const parsedCache = JSON.parse(rawCache) as unknown;
      translateWindow.__consueloTranslationCache =
        parsedCache && typeof parsedCache === 'object' ? (parsedCache as Record<string, string>) : {};
    } catch {
      translateWindow.__consueloTranslationCache = {};
    }

    return translateWindow.__consueloTranslationCache;
  };

  const writeTranslationCache = (cache: Record<string, string>) => {
    const cacheEntries = Object.entries(cache);
    const trimmedCache =
      cacheEntries.length > MAX_CACHED_TRANSLATIONS
        ? Object.fromEntries(cacheEntries.slice(-MAX_CACHED_TRANSLATIONS))
        : cache;

    translateWindow.__consueloTranslationCache = trimmedCache;

    try {
      window.localStorage.setItem(TRANSLATION_CACHE_KEY, JSON.stringify(trimmedCache));
    } catch {
      translateWindow.__consueloTranslationCache = trimmedCache;
    }
  };

  const getTranslationCacheKey = (languageCode: string, text: string) => {
    return `${languageCode}::${text}`;
  };

  const wait = (duration: number) => {
    return new Promise<void>((resolve) => {
      window.setTimeout(resolve, duration);
    });
  };

  const smoothScrollToTop = async () => {
    const currentScroll = window.scrollY;

    if (currentScroll <= 16) {
      return;
    }

    const duration = Math.min(900, Math.max(250, Math.round(currentScroll * 0.35)));

    window.scrollTo({ top: 0, behavior: 'smooth' });
    await wait(duration);
    window.scrollTo({ top: 0, behavior: 'auto' });
  };

  const setTranslationLoadingState = (isLoading: boolean) => {
    document.body.toggleAttribute('data-language-translating', isLoading);
  };

  const getStoredLanguage = () => {
    return window.localStorage.getItem(STORAGE_KEY) ?? 'en';
  };

  const setStoredLanguage = (languageCode: string) => {
    if (languageCode === 'en') {
      window.localStorage.removeItem(STORAGE_KEY);
      return;
    }

    window.localStorage.setItem(STORAGE_KEY, languageCode);
  };

  const getLanguageLabel = (languageCode: string) => {
    const option = document.querySelector(`[data-language-code="${languageCode}"]`);

    return option instanceof HTMLButtonElement ? option.textContent?.trim() ?? 'English' : 'English';
  };

  const collectTranslateTargets = (): TranslateTarget[] => {
    const textTargets: TranslateTextTarget[] = [];
    const textWalker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT);

    while (textWalker.nextNode()) {
      const node = textWalker.currentNode;

      if (!(node instanceof Text)) {
        continue;
      }

      const parent = node.parentElement;
      const cachedText = textCache.get(node);
      const originalText = typeof cachedText === 'string' ? cachedText : node.textContent ?? '';

      if (!parent || !originalText.trim()) {
        continue;
      }

      if (IGNORED_TAGS.has(parent.tagName) || parent.closest('[data-translate-ignore]')) {
        continue;
      }

      if (typeof cachedText !== 'string') {
        textCache.set(node, originalText);
      }

      textTargets.push({ kind: 'text', node, originalText });
    }

    const attributeTargets: TranslateAttributeTarget[] = [];

    document.querySelectorAll('input[placeholder], textarea[placeholder], [aria-label], [title]').forEach((element) => {
      if (!(element instanceof HTMLElement) || element.closest('[data-translate-ignore]')) {
        return;
      }

      const placeholder = element.getAttribute('placeholder');
      const ariaLabel = element.getAttribute('aria-label');
      const title = element.getAttribute('title');
      const cachedAttributes = attributeCache.get(element) ?? {};

      if (placeholder?.trim()) {
        if (typeof cachedAttributes.placeholder !== 'string') {
          cachedAttributes.placeholder = placeholder;
        }

        attributeTargets.push({ kind: 'attribute', element, attributeName: 'placeholder', originalText: cachedAttributes.placeholder });
      }

      if (ariaLabel?.trim()) {
        if (typeof cachedAttributes['aria-label'] !== 'string') {
          cachedAttributes['aria-label'] = ariaLabel;
        }

        attributeTargets.push({ kind: 'attribute', element, attributeName: 'aria-label', originalText: cachedAttributes['aria-label'] });
      }

      if (title?.trim()) {
        if (typeof cachedAttributes.title !== 'string') {
          cachedAttributes.title = title;
        }

        attributeTargets.push({ kind: 'attribute', element, attributeName: 'title', originalText: cachedAttributes.title });
      }

      attributeCache.set(element, cachedAttributes);
    });

    return [...textTargets, ...attributeTargets];
  };

  const restoreOriginalContent = (targets: TranslateTarget[]) => {
    targets.forEach((target: TranslateTarget) => {
      if (target.kind === 'text') {
        target.node.textContent = target.originalText;
        return;
      }

      target.element.setAttribute(target.attributeName, target.originalText);
    });
  };

  const applyTranslatedContent = (
    targets: TranslateTarget[],
    translatedTexts: unknown[],
  ) => {
    targets.forEach((target: TranslateTarget, index: number) => {
      const translatedText = translatedTexts[index];

      if (typeof translatedText !== 'string') {
        return;
      }

      if (target.kind === 'text') {
        target.node.textContent = translatedText;
        return;
      }

      target.element.setAttribute(target.attributeName, translatedText);
    });
  };

  const chunkTexts = (texts: string[]) => {
    const batches: string[][] = [];
    let currentBatch: string[] = [];
    let currentLength = 0;

    texts.forEach((text) => {
      const projectedLength = currentLength + text.length + SPLIT_TOKEN.length;

      if (currentBatch.length > 0 && projectedLength > MAX_BATCH_CHARACTERS) {
        batches.push(currentBatch);
        currentBatch = [];
        currentLength = 0;
      }

      currentBatch.push(text);
      currentLength += text.length + SPLIT_TOKEN.length;
    });

    if (currentBatch.length > 0) {
      batches.push(currentBatch);
    }

    return batches;
  };

  const translateBatch = async (texts: string[], languageCode: string) => {
    const query = new URLSearchParams({
      client: 'gtx',
      dt: 't',
      q: texts.join(`\n${SPLIT_TOKEN}\n`),
      sl: 'en',
      tl: languageCode,
    });

    const response = await fetch(`${GOOGLE_TRANSLATE_ENDPOINT}?${query.toString()}`);

    if (!response.ok) {
      throw new Error('translation failed');
    }

    const payload = (await response.json()) as unknown;

    if (!Array.isArray(payload) || !Array.isArray(payload[0])) {
      throw new Error('translation response invalid');
    }

    const translatedText = payload[0]
      .map((item) => {
        return Array.isArray(item) && typeof item[0] === 'string' ? item[0] : '';
      })
      .join('');

    return translatedText.split(SPLIT_TOKEN);
  };

  const getTranslatedTexts = async (texts: string[], languageCode: string) => {
    const translationCache = readTranslationCache();
    const translatedTexts = new Array<string>(texts.length);
    const missingTexts: string[] = [];
    const missingIndexes: number[] = [];

    texts.forEach((text, index) => {
      const cachedText = translationCache[getTranslationCacheKey(languageCode, text)];

      if (typeof cachedText === 'string') {
        translatedTexts[index] = cachedText;
        return;
      }

      missingTexts.push(text);
      missingIndexes.push(index);
    });

    if (missingTexts.length > 0) {
      const fetchedTranslations: string[] = [];

      for (const batch of chunkTexts(missingTexts)) {
        const translatedBatch = await translateBatch(batch, languageCode);
        fetchedTranslations.push(...translatedBatch);
      }

      if (fetchedTranslations.length !== missingTexts.length) {
        throw new Error('translation response invalid');
      }

      fetchedTranslations.forEach((translatedText, index) => {
        const originalText = missingTexts[index];
        const targetIndex = missingIndexes[index];

        translationCache[getTranslationCacheKey(languageCode, originalText)] = translatedText;
        translatedTexts[targetIndex] = translatedText;
      });

      writeTranslationCache(translationCache);
    }

    return translatedTexts;
  };

  const initializeLanguageSelector = () => {
    const root = document.querySelector('[data-language-selector]');
    const trigger = document.querySelector('[data-language-trigger]');
    const menu = document.querySelector('[data-language-menu]');
    const currentLabel = document.querySelector('[data-language-label]');
    const options = Array.from(document.querySelectorAll('[data-language-code]'));

    if (
      !(root instanceof HTMLElement) ||
      !(trigger instanceof HTMLButtonElement) ||
      !(menu instanceof HTMLElement) ||
      !(currentLabel instanceof HTMLElement)
    ) {
      return;
    }

    if (root.dataset.initialized === 'true') {
      currentLabel.textContent = getLanguageLabel(getStoredLanguage());
      return;
    }

    root.dataset.initialized = 'true';
    let activeTranslationRequest = 0;

    const updateLabel = (languageCode: string) => {
      currentLabel.textContent = getLanguageLabel(languageCode);
    };

    const closeMenu = () => {
      trigger.setAttribute('aria-expanded', 'false');
      menu.classList.remove('language-selector__menu--open');
    };

    const runTranslation = async (
      languageCode: string,
      options: { shouldScrollToTop: boolean },
    ) => {
      const requestId = ++activeTranslationRequest;
      const targets = collectTranslateTargets();
      const scrollPromise = options.shouldScrollToTop ? smoothScrollToTop() : Promise.resolve();

      setTranslationLoadingState(true);

      if (languageCode === 'en') {
        try {
          await scrollPromise;

          if (requestId !== activeTranslationRequest) {
            return;
          }

          restoreOriginalContent(targets);
          setStoredLanguage('en');
          updateLabel('en');
        } finally {
          if (requestId === activeTranslationRequest) {
            setTranslationLoadingState(false);
          }
        }

        return;
      }

      try {
        const translationPromise = getTranslatedTexts(
          targets.map((target: TranslateTarget) => target.originalText),
          languageCode,
        );

        const [translatedTexts] = await Promise.all([translationPromise, scrollPromise]);

        if (requestId !== activeTranslationRequest) {
          return;
        }

        restoreOriginalContent(targets);
        applyTranslatedContent(targets, translatedTexts);
        setStoredLanguage(languageCode);
        updateLabel(languageCode);
      } finally {
        if (requestId === activeTranslationRequest) {
          setTranslationLoadingState(false);
        }
      }
    };

    trigger.addEventListener('click', (event) => {
      event.stopPropagation();
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      menu.classList.toggle('language-selector__menu--open', !isOpen);
    });

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Node) || !root.contains(event.target)) {
        closeMenu();
      }
    });

    options.forEach((option) => {
      if (!(option instanceof HTMLButtonElement)) {
        return;
      }

      option.addEventListener('click', async () => {
        const languageCode = option.dataset.languageCode;

        if (!languageCode) {
          return;
        }

        closeMenu();

        try {
          await runTranslation(languageCode, { shouldScrollToTop: true });
        } catch {
          updateLabel(getStoredLanguage());
        }
      });
    });

    const initialLanguage = getStoredLanguage();
    updateLabel(initialLanguage);

    if (initialLanguage !== 'en') {
      runTranslation(initialLanguage, { shouldScrollToTop: false }).catch(() => {
        setStoredLanguage('en');
        updateLabel('en');
      });
    }
  };

  initializeLanguageSelector();
  document.addEventListener('astro:after-swap', initializeLanguageSelector);
</script>

<style>
  .language-selector {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .language-selector__button {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--launch-muted);
    font-size: 0.82rem;
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .language-selector__button:hover,
  .language-selector__button:focus-visible {
    color: var(--launch-fg);
    outline: none;
  }

  .language-selector__menu {
    position: absolute;
    right: 0;
    bottom: calc(100% + 0.5rem);
    display: none;
    min-width: 10rem;
    padding: 0.4rem 0;
    border: 1px solid var(--launch-line);
    background: var(--launch-dropdown-bg);
    box-shadow: var(--launch-dropdown-shadow);
    backdrop-filter: blur(10px);
    z-index: 50;
  }

  .language-selector__menu--open {
    display: flex;
    flex-direction: column;
  }

  .language-selector__option {
    width: 100%;
    padding: 0.55rem 1rem;
    border: 0;
    background: transparent;
    color: var(--launch-muted);
    font-size: 0.82rem;
    text-align: left;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .language-selector__option:hover,
  .language-selector__option:focus-visible {
    background: rgba(255, 255, 255, 0.05);
    color: var(--launch-fg);
    outline: none;
  }
</style>
