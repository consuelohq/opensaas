---
import { siteLinks } from '../../data/site-links'

type Props = {
	pageSections?: HomePageSection[]
}

type HomePageSection = {
	id: string
	label: string
}

const { pageSections = [] } = Astro.props as Props
const hasPageSections = pageSections.length > 0
const portalHref = 'https://os.consuelohq.com'
const installHref = 'https://os.consuelohq.com/install.sh'
---

<header class="launch-header" data-launch-header data-motion="hero-header">
	<nav class="launch-content launch-content--wide launch-header__desktop" aria-label="Primary">
		<a class="launch-header__brand" data-header-brand href="/">Consuelo</a>
		<a class="launch-header__link" data-desktop-header-slot href={siteLinks.docs}>Docs</a>
		<div class="launch-header__center" data-desktop-header-slot>
			<a class="launch-header__center-label" href="/" aria-label="Consuelo OS home">Consuelo OS</a>
			<span class="launch-header__socials" aria-label="Community links">
				<a class="launch-header__social" href={siteLinks.discord} aria-label="Discord">
					<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19.54 5.23a16.9 16.9 0 0 0-4.25-1.31.06.06 0 0 0-.07.03c-.18.32-.38.73-.52 1.06a15.7 15.7 0 0 0-4.72 0 10.8 10.8 0 0 0-.53-1.06.07.07 0 0 0-.07-.03 16.85 16.85 0 0 0-4.25 1.31.06.06 0 0 0-.03.03C2.42 9.26 1.7 13.17 2.06 17.03c0 .02.01.04.03.05a17.02 17.02 0 0 0 5.22 2.64.07.07 0 0 0 .07-.02c.4-.55.76-1.12 1.07-1.73a.07.07 0 0 0-.04-.1 11.2 11.2 0 0 1-1.64-.78.07.07 0 0 1 0-.12c.11-.08.22-.17.33-.26a.07.07 0 0 1 .07 0c3.15 1.44 6.56 1.44 9.67 0a.07.07 0 0 1 .08 0c.1.09.21.18.33.26a.07.07 0 0 1 0 .12c-.52.31-1.07.57-1.64.78a.07.07 0 0 0-.04.1c.32.61.67 1.18 1.07 1.73a.07.07 0 0 0 .07.02 16.96 16.96 0 0 0 5.23-2.64.07.07 0 0 0 .03-.05c.44-4.47-.74-8.35-3.03-11.77a.06.06 0 0 0-.03-.03ZM8.68 14.68c-.95 0-1.73-.87-1.73-1.94s.76-1.94 1.73-1.94c.96 0 1.74.88 1.73 1.94 0 1.07-.77 1.94-1.73 1.94Zm6.65 0c-.95 0-1.73-.87-1.73-1.94s.76-1.94 1.73-1.94c.96 0 1.74.88 1.73 1.94 0 1.07-.77 1.94-1.73 1.94Z" /></svg>
				</a>
				<a class="launch-header__social" href={siteLinks.github} aria-label="GitHub">
					<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .5a11.5 11.5 0 0 0-3.64 22.41c.58.1.79-.25.79-.56v-2.02c-3.22.7-3.9-1.38-3.9-1.38-.53-1.34-1.3-1.7-1.3-1.7-1.06-.73.08-.72.08-.72 1.17.08 1.79 1.2 1.79 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.76.4-1.27.74-1.56-2.57-.29-5.27-1.29-5.27-5.72 0-1.27.45-2.3 1.2-3.11-.12-.29-.52-1.47.11-3.07 0 0 .98-.31 3.2 1.19a11.1 11.1 0 0 1 5.82 0c2.22-1.5 3.2-1.19 3.2-1.19.63 1.6.23 2.78.11 3.07.75.82 1.2 1.85 1.2 3.11 0 4.45-2.7 5.43-5.28 5.72.41.36.78 1.07.78 2.15v3.06c0 .31.21.67.8.56A11.5 11.5 0 0 0 12 .5Z" /></svg>
				</a>
			</span>
		</div>
		<a class="launch-header__link" data-desktop-header-slot href={portalHref}>Portal</a>
		<a class="launch-header__link" data-desktop-header-slot href={installHref}>
			<span>Install</span>
			<span aria-hidden="true">→</span>
		</a>
	</nav>

	<nav
		class="launch-content launch-content--wide launch-header__mobile"
		aria-label="Mobile primary"
	>
		<a class="launch-header__mobile-link" data-mobile-header-slot href={portalHref}>Portal</a>
		<div class="launch-header__mobile-center" data-mobile-header-slot>
			<a class="launch-header__mobile-link launch-header__mobile-link--center" href="/">Consuelo OS</a>
			<span class="launch-header__socials launch-header__socials--mobile" aria-label="Community links">
				<a class="launch-header__social" href={siteLinks.discord} aria-label="Discord"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19.54 5.23a16.9 16.9 0 0 0-4.25-1.31.06.06 0 0 0-.07.03c-.18.32-.38.73-.52 1.06a15.7 15.7 0 0 0-4.72 0 10.8 10.8 0 0 0-.53-1.06.07.07 0 0 0-.07-.03 16.85 16.85 0 0 0-4.25 1.31.06.06 0 0 0-.03.03C2.42 9.26 1.7 13.17 2.06 17.03c0 .02.01.04.03.05a17.02 17.02 0 0 0 5.22 2.64.07.07 0 0 0 .07-.02c.4-.55.76-1.12 1.07-1.73a.07.07 0 0 0-.04-.1 11.2 11.2 0 0 1-1.64-.78.07.07 0 0 1 0-.12c.11-.08.22-.17.33-.26a.07.07 0 0 1 .07 0c3.15 1.44 6.56 1.44 9.67 0a.07.07 0 0 1 .08 0c.1.09.21.18.33.26a.07.07 0 0 1 0 .12c-.52.31-1.07.57-1.64.78a.07.07 0 0 0-.04.1c.32.61.67 1.18 1.07 1.73a.07.07 0 0 0 .07.02 16.96 16.96 0 0 0 5.23-2.64.07.07 0 0 0 .03-.05c.44-4.47-.74-8.35-3.03-11.77a.06.06 0 0 0-.03-.03ZM8.68 14.68c-.95 0-1.73-.87-1.73-1.94s.76-1.94 1.73-1.94c.96 0 1.74.88 1.73 1.94 0 1.07-.77 1.94-1.73 1.94Zm6.65 0c-.95 0-1.73-.87-1.73-1.94s.76-1.94 1.73-1.94c.96 0 1.74.88 1.73 1.94 0 1.07-.77 1.94-1.73 1.94Z" /></svg></a>
				<a class="launch-header__social" href={siteLinks.github} aria-label="GitHub"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .5a11.5 11.5 0 0 0-3.64 22.41c.58.1.79-.25.79-.56v-2.02c-3.22.7-3.9-1.38-3.9-1.38-.53-1.34-1.3-1.7-1.3-1.7-1.06-.73.08-.72.08-.72 1.17.08 1.79 1.2 1.79 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.76.4-1.27.74-1.56-2.57-.29-5.27-1.29-5.27-5.72 0-1.27.45-2.3 1.2-3.11-.12-.29-.52-1.47.11-3.07 0 0 .98-.31 3.2 1.19a11.1 11.1 0 0 1 5.82 0c2.22-1.5 3.2-1.19 3.2-1.19.63 1.6.23 2.78.11 3.07.75.82 1.2 1.85 1.2 3.11 0 4.45-2.7 5.43-5.28 5.72.41.36.78 1.07.78 2.15v3.06c0 .31.21.67.8.56A11.5 11.5 0 0 0 12 .5Z" /></svg></a>
			</span>
		</div>
		<a
			class="launch-header__mobile-link launch-header__mobile-link--right"
			data-mobile-header-slot
			href={siteLinks.docs}>Docs</a
		>
	</nav>

	{
		hasPageSections && (
			<div class="launch-header__page-nav" data-page-nav>
				<div class="launch-header__page-nav-scroll">
					{pageSections.map((section) => (
						<a class="launch-header__page-link" href={'#' + section.id} data-page-anchor>
							{section.label}
						</a>
					))}
				</div>
			</div>
		)
	}
</header>

<style>
	.launch-header {
		--launch-bg: var(--site-color-paper);
		--launch-fg: var(--site-color-ink);
		--launch-muted: var(--site-color-muted);
		--launch-line: var(--site-color-line);
		z-index: 1;
		background: var(--launch-bg);
		color: var(--launch-fg);
	}

	:global(html[data-hero-motion-ready='true']) .launch-header[data-motion='hero-header'] {
		opacity: 0;
		transform: translate3d(0, -0.65rem, 0);
		will-change: opacity, transform;
	}

	@media (prefers-reduced-motion: reduce) {
		:global(html[data-hero-motion-ready='true']) .launch-header[data-motion='hero-header'] {
			opacity: 1;
			transform: none;
			will-change: auto;
		}
	}

	.launch-header__desktop {
		min-height: 5.75rem;
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		align-items: start;
		gap: 1rem;
		padding-block: 1.35rem 1rem;
	}

	.launch-header__brand,
	.launch-header__link,
	.launch-header__mobile-link,
	.launch-header__page-link {
		font-family: var(--site-font-mono);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0;
		line-height: 1;
	}

	.launch-header__brand,
	.launch-header__link,
	.launch-header__center,
	.launch-header__mobile-link,
	.launch-header__page-link {
		transition:
			color 160ms ease,
			opacity 160ms ease;
	}

	.launch-header__brand,
	.launch-header__link,
	.launch-header__center {
		justify-self: center;
		white-space: nowrap;
	}

	.launch-header__center,
	.launch-header__mobile-center {
		display: inline-grid;
		justify-items: center;
		gap: 0.42rem;
		color: var(--launch-fg);
		text-align: center;
	}

	.launch-header__center-label,
	.launch-header__mobile-link--center {
		color: currentColor;
		font-family: var(--site-font-display);
		font-size: 1.7rem;
		font-weight: 700;
		letter-spacing: 0;
		line-height: 0.95;
		text-align: center;
	}

	.launch-header__link {
		display: inline-flex;
		align-items: center;
		gap: 0.28rem;
	}

	.launch-header__socials {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}

	.launch-header__social {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--launch-muted);
		line-height: 1;
	}

	.launch-header__social svg {
		width: 0.88rem;
		height: 0.88rem;
		fill: currentColor;
	}

	.launch-header__brand:hover,
	.launch-header__link:hover,
	.launch-header__center-label:hover,
	.launch-header__social:hover,
	.launch-header__mobile-link:hover,
	.launch-header__page-link:hover {
		color: var(--launch-muted);
	}

	.launch-header__mobile {
		min-height: 3.8rem;
		display: none;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		align-items: center;
		gap: 1rem;
		padding-block: 0.95rem;
	}

	.launch-header__mobile-link {
		white-space: nowrap;
	}

	.launch-header__mobile-center {
		justify-self: center;
		gap: 0.34rem;
	}

	.launch-header__mobile-link--center {
		font-size: 1.16rem;
		line-height: 1;
	}

	.launch-header__mobile-link--right {
		justify-self: end;
	}

	.launch-header__page-nav {
		border-top: 1px solid var(--launch-line);
		overflow-x: auto;
		scrollbar-width: none;
	}

	.launch-header__page-nav::-webkit-scrollbar {
		display: none;
	}

	.launch-header__page-nav-scroll {
		display: flex;
		gap: 0.4rem;
		min-width: max-content;
		padding: 0.7rem 1rem;
	}

	.launch-header__page-link {
		color: var(--launch-muted);
		padding: 0.38rem 0.6rem;
		white-space: nowrap;
	}

	@media (max-width: 640px) {
		.launch-header__desktop {
			display: none;
		}

		.launch-header__mobile {
			display: grid;
		}
	}

	@media (max-width: 360px) {
		.launch-header__mobile {
			gap: 0.65rem;
		}

		.launch-header__mobile-link {
			font-size: 0.72rem;
		}

		.launch-header__mobile-link--center {
			font-size: 1rem;
		}
	}
</style>
