---
import { siteLinks } from '../../data/site-links'

type Props = {
	pageSections?: HomePageSection[]
}

type HomePageSection = {
	id: string
	label: string
}

const { pageSections = [] } = Astro.props as Props
const hasPageSections = pageSections.length > 0
const portalHref = 'https://os.consuelohq.com'
const installHref = 'https://os.consuelohq.com/install.sh'
---

<header class="launch-header" data-launch-header data-motion="hero-header">
	<nav class="launch-content launch-content--wide launch-header__desktop" aria-label="Primary">
		<a class="launch-header__brand" data-header-brand href="/">Consuelo</a>
		<a class="launch-header__link" data-desktop-header-slot href={siteLinks.docs}>Docs</a>
		<a
			class="launch-header__center"
			data-desktop-header-slot
			href="/"
			aria-label="Consuelo OS home"
		>
			Consuelo OS
		</a>
		<a class="launch-header__link" data-desktop-header-slot href={portalHref}>Portal</a>
		<a class="launch-header__link" data-desktop-header-slot href={installHref}>
			<span>Install</span>
			<span aria-hidden="true">→</span>
		</a>
	</nav>

	<nav
		class="launch-content launch-content--wide launch-header__mobile"
		aria-label="Mobile primary"
	>
		<a class="launch-header__mobile-link" data-mobile-header-slot href={portalHref}>Portal</a>
		<a
			class="launch-header__mobile-link launch-header__mobile-link--center"
			data-mobile-header-slot
			href="/"
		>
			Consuelo OS
		</a>
		<a
			class="launch-header__mobile-link launch-header__mobile-link--right"
			data-mobile-header-slot
			href={siteLinks.docs}>Docs</a
		>
	</nav>

	{
		hasPageSections && (
			<div class="launch-header__page-nav" data-page-nav>
				<div class="launch-header__page-nav-scroll">
					{pageSections.map((section) => (
						<a class="launch-header__page-link" href={'#' + section.id} data-page-anchor>
							{section.label}
						</a>
					))}
				</div>
			</div>
		)
	}
</header>

<style>
	.launch-header {
		z-index: 1;
		background: var(--launch-bg);
		color: var(--launch-fg);
	}

	:global(html[data-hero-motion-ready='true']) .launch-header[data-motion='hero-header'] {
		opacity: 0;
		transform: translate3d(0, -0.65rem, 0);
		will-change: opacity, transform;
	}

	@media (prefers-reduced-motion: reduce) {
		:global(html[data-hero-motion-ready='true']) .launch-header[data-motion='hero-header'] {
			opacity: 1;
			transform: none;
			will-change: auto;
		}
	}

	.launch-header__desktop {
		min-height: 5.75rem;
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		align-items: start;
		gap: 1rem;
		padding-block: 1.35rem 1rem;
	}

	.launch-header__brand,
	.launch-header__link,
	.launch-header__mobile-link,
	.launch-header__page-link {
		font-family: var(--site-font-mono);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0;
		line-height: 1;
	}

	.launch-header__brand,
	.launch-header__link,
	.launch-header__center,
	.launch-header__mobile-link,
	.launch-header__page-link {
		transition:
			color 160ms ease,
			opacity 160ms ease;
	}

	.launch-header__brand,
	.launch-header__link,
	.launch-header__center {
		justify-self: center;
		white-space: nowrap;
	}

	.launch-header__center {
		color: var(--launch-fg);
		font-family: var(--site-font-display);
		font-size: 1.7rem;
		font-weight: 700;
		letter-spacing: 0;
		line-height: 0.95;
		text-align: center;
	}

	.launch-header__link {
		display: inline-flex;
		align-items: center;
		gap: 0.28rem;
	}

	.launch-header__brand:hover,
	.launch-header__link:hover,
	.launch-header__center:hover,
	.launch-header__mobile-link:hover,
	.launch-header__page-link:hover {
		color: var(--launch-muted);
	}

	.launch-header__mobile {
		min-height: 3.8rem;
		display: none;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		align-items: center;
		gap: 1rem;
		padding-block: 0.95rem;
	}

	.launch-header__mobile-link {
		white-space: nowrap;
	}

	.launch-header__mobile-link--center {
		justify-self: center;
		font-family: var(--site-font-display);
		font-size: 1.16rem;
		line-height: 1;
	}

	.launch-header__mobile-link--right {
		justify-self: end;
	}

	.launch-header__page-nav {
		border-top: 1px solid var(--launch-line);
		overflow-x: auto;
		scrollbar-width: none;
	}

	.launch-header__page-nav::-webkit-scrollbar {
		display: none;
	}

	.launch-header__page-nav-scroll {
		display: flex;
		gap: 0.4rem;
		min-width: max-content;
		padding: 0.7rem 1rem;
	}

	.launch-header__page-link {
		color: var(--launch-muted);
		padding: 0.38rem 0.6rem;
		white-space: nowrap;
	}

	@media (max-width: 640px) {
		.launch-header__desktop {
			display: none;
		}

		.launch-header__mobile {
			display: grid;
		}
	}

	@media (max-width: 360px) {
		.launch-header__mobile {
			gap: 0.65rem;
		}

		.launch-header__mobile-link {
			font-size: 0.72rem;
		}

		.launch-header__mobile-link--center {
			font-size: 1rem;
		}
	}
</style>
