---
import LinkButton from "./LinkButton.astro";
import LanguageSelector from "./site/LanguageSelector.astro";
import { SITE } from "@/config";
---

{
  SITE.showBackButton && (
    <div class="app-layout flex items-center gap-4 mt-8 mb-1">
      <LinkButton
        id="back-button"
        href="/blog"
        class="focus-outline text-sm hover:opacity-75"
        style="color: #B3B3B3;"
      >
        <span>home</span>
      </LinkButton>
      <LanguageSelector />
    </div>
  )
}

<script>
  function updateGoBackUrl() {
    const backButton = document.querySelector("#back-button");
  const backUrl = sessionStorage.getItem("backUrl");
  if (backUrl && backButton) {
    (backButton as HTMLAnchorElement).href = backUrl;
  }
  }
  document.addEventListener("astro:page-load", updateGoBackUrl);
  updateGoBackUrl();
</script>
