---
import { homeTabs } from '../../data/home-content';

type Props = {
  sectionId?: string;
};

const { sectionId } = Astro.props as Props;
const osPortalHref = 'https://os.consuelohq.com';
---

<section class="home-hero site-section" id={sectionId} data-section="hero">
  <div class="home-hero__inner site-container site-container--wide">
    <div class="home-hero__content">
      <p class="home-hero__eyebrow site-eyebrow" aria-label="Batteries included and MIT licensed">
        <span>BATTERIES INCLUDED</span>
        <span class="home-hero__eyebrow-dot" aria-hidden="true">•</span>
        <span>MIT LICENSE</span>
      </p>

      <h1 class="home-hero__title">
        Give every agent workspace <em>superpowers</em>.
      </h1>

      <div class="home-hero__actions" aria-label="Use Consuelo OS Cloud">
        <p class="home-hero__action-label site-eyebrow">USE CONSUELO OS CLOUD</p>
        <a class="home-hero__portal site-button site-button--secondary" href={osPortalHref}>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M7.5 18.5h9a4 4 0 0 0 .7-7.94A5.8 5.8 0 0 0 6.02 9.1a4.75 4.75 0 0 0 1.48 9.4Z" />
          </svg>
          <span>Go to OS portal</span>
          <span class="home-hero__portal-arrow" aria-hidden="true">→</span>
        </a>
      </div>

      <div class="home-hero__install site-card" data-hero-install>
        <div class="home-hero__tabs" role="tablist" aria-label="Consuelo install and workspace surfaces">
          {homeTabs.map((tab, index) => (
            <button
              class:list={['home-hero__tab', { 'is-active': index === 0 }]}
              type="button"
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              data-tab-button={tab.id}
            >
              {tab.label}
            </button>
          ))}
        </div>

        <div class="home-hero__panels">
          {homeTabs.map((tab, index) => tab.kind === 'link' && tab.href ? (
            <a
              href={tab.href}
              class:list={['home-hero__panel', { 'is-active': index === 0 }]}
              data-tab-panel={tab.id}
            >
              <span class="home-hero__value">{tab.value}</span>
              <span class="home-hero__panel-action" aria-hidden="true">→</span>
            </a>
          ) : (
            <button
              type="button"
              class:list={['home-hero__panel', { 'is-active': index === 0 }]}
              data-tab-panel={tab.id}
              data-copy-button={tab.id}
            >
              <code class="home-hero__value">{tab.value}</code>
              <span class="home-hero__panel-action" aria-hidden="true">
                <svg class="home-hero__copy-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
                  <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
                </svg>
                <svg class="home-hero__check-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </span>
            </button>
          ))}
        </div>
      </div>
    </div>

    <figure class="home-hero__diagram site-card" aria-label="Consuelo integrations diagram">
      <img
        src="/images/consuelo-integrations-hero.svg"
        alt="Developer tools and work surfaces connected to Consuelo"
        loading="eager"
        decoding="async"
      />
    </figure>
  </div>
</section>

<script define:vars={{ homeTabs }}>
  const root = document.querySelector('[data-hero-install]');

  if (root instanceof HTMLElement) {
    const buttons = Array.from(root.querySelectorAll('[data-tab-button]'));
    const panels = Array.from(root.querySelectorAll('[data-tab-panel]'));
    const copyButtons = Array.from(root.querySelectorAll('[data-copy-button]'));

    const sync = (nextIndex) => {
      buttons.forEach((button, index) => {
        const isActive = index === nextIndex;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      panels.forEach((panel, index) => panel.classList.toggle('is-active', index === nextIndex));
    };

    buttons.forEach((button, index) => {
      button.addEventListener('click', () => sync(index));
    });

    copyButtons.forEach((button) => {
      button.addEventListener('click', async () => {
        const tabId = button.getAttribute('data-copy-button');
        const entry = homeTabs.find((tab) => tab.id === tabId);

        if (!entry || !navigator.clipboard) {
          return;
        }

        await navigator.clipboard.writeText(entry.value);
        button.classList.add('is-copied');
        window.setTimeout(() => button.classList.remove('is-copied'), 1400);
      });
    });

    sync(0);
  }
</script>

<style>
  .home-hero {
    min-height: calc(100svh - var(--site-space-8));
    display: grid;
    align-items: center;
    background:
      radial-gradient(circle at top left, color-mix(in srgb, var(--site-color-accent) 9%, transparent), transparent 34rem),
      var(--site-color-paper);
    color: var(--site-color-ink);
    padding-block: var(--site-space-section) var(--site-space-8);
  }

  .home-hero__inner {
    display: grid;
    gap: var(--site-space-8);
    align-items: center;
  }

  .home-hero__content {
    display: grid;
    gap: var(--site-space-6);
    max-width: 46rem;
  }

  .home-hero__eyebrow {
    color: var(--site-color-accent);
    display: flex;
    gap: var(--site-space-4);
    align-items: center;
  }

  .home-hero__eyebrow-dot {
    color: var(--site-color-muted);
  }

  .home-hero__title {
    margin: 0;
    color: var(--site-color-ink);
    font-family: var(--site-font-body);
    font-size: clamp(var(--site-text-3xl), 7vw, var(--site-text-4xl));
    font-weight: 800;
    letter-spacing: var(--site-tracking-display);
    line-height: var(--site-leading-tight);
    text-wrap: balance;
  }

  .home-hero__title em {
    color: var(--site-color-accent);
    font-family: var(--site-font-display);
    font-style: italic;
    font-weight: 500;
    letter-spacing: var(--site-tracking-tight);
  }

  .home-hero__actions {
    display: grid;
    gap: var(--site-space-4);
    width: min(100%, 20rem);
  }

  .home-hero__action-label {
    color: var(--site-color-accent);
  }

  .home-hero__portal {
    min-height: calc(var(--site-space-7) + var(--site-space-2));
    justify-content: space-between;
    border-color: var(--site-color-line);
    background: color-mix(in srgb, var(--site-color-surface) 86%, transparent);
    color: var(--site-color-ink);
    box-shadow: var(--site-shadow-border);
  }

  .home-hero__portal svg {
    width: var(--site-space-5);
    height: var(--site-space-5);
    fill: currentColor;
  }

  .home-hero__portal-arrow {
    color: var(--site-color-accent);
    font-family: var(--site-font-mono);
    font-weight: 700;
  }

  .home-hero__install {
    overflow: hidden;
    padding: 0;
    background: var(--site-color-surface);
    box-shadow: var(--site-shadow-border);
  }

  .home-hero__tabs {
    display: flex;
    gap: var(--site-space-1);
    overflow-x: auto;
    overflow-y: hidden;
    border-bottom: 1px solid var(--site-color-line);
    padding: var(--site-space-2) var(--site-space-3) 0;
    scrollbar-width: none;
  }

  .home-hero__tabs::-webkit-scrollbar {
    display: none;
  }

  .home-hero__tab {
    border: 0;
    border-bottom: 2px solid transparent;
    background: transparent;
    color: var(--site-color-muted);
    font: 700 var(--site-text-sm) / 1 var(--site-font-body);
    padding: var(--site-space-3) var(--site-space-4);
    white-space: nowrap;
  }

  .home-hero__tab:hover,
  .home-hero__tab:focus-visible {
    color: var(--site-color-ink);
    outline: none;
  }

  .home-hero__tab.is-active {
    border-bottom-color: var(--site-color-accent);
    color: var(--site-color-ink);
  }

  .home-hero__panels {
    background: color-mix(in srgb, var(--site-color-ink) 3%, var(--site-color-surface));
  }

  .home-hero__panel {
    display: none;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    gap: var(--site-space-4);
    border: 0;
    background: transparent;
    color: var(--site-color-ink);
    cursor: pointer;
    padding: var(--site-space-5) var(--site-space-5);
    text-align: left;
    text-decoration: none;
    transition:
      background var(--site-motion-fast) var(--site-ease-standard),
      color var(--site-motion-fast) var(--site-ease-standard);
  }

  .home-hero__panel.is-active {
    display: flex;
  }

  .home-hero__panel:hover,
  .home-hero__panel:focus-visible {
    background: color-mix(in srgb, var(--site-color-accent) 7%, transparent);
    outline: none;
  }

  .home-hero__value {
    min-width: 0;
    color: var(--site-color-ink);
    font: 500 var(--site-text-sm) / var(--site-leading-body) var(--site-font-mono);
    overflow-wrap: anywhere;
  }

  .home-hero__panel-action {
    width: var(--site-space-6);
    height: var(--site-space-6);
    border-radius: var(--site-radius-sm);
    color: var(--site-color-muted);
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    font-family: var(--site-font-mono);
  }

  .home-hero__panel:hover .home-hero__panel-action,
  .home-hero__panel:focus-visible .home-hero__panel-action {
    color: var(--site-color-accent);
    background: color-mix(in srgb, var(--site-color-accent) 9%, transparent);
  }

  .home-hero__panel-action svg {
    width: var(--site-space-4);
    height: var(--site-space-4);
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.5;
  }

  .home-hero__check-icon {
    display: none;
  }

  .home-hero__panel.is-copied .home-hero__panel-action {
    color: var(--site-color-secondary);
  }

  .home-hero__panel.is-copied .home-hero__copy-icon {
    display: none;
  }

  .home-hero__panel.is-copied .home-hero__check-icon {
    display: block;
  }

  .home-hero__diagram {
    position: relative;
    margin: 0;
    padding: var(--site-space-6);
    overflow: hidden;
    background: color-mix(in srgb, var(--site-color-surface) 80%, transparent);
    border-radius: var(--site-radius-card);
    box-shadow: var(--site-shadow-raised);
  }

  .home-hero__diagram img {
    width: 100%;
    height: auto;
  }

  @media (min-width: 940px) {
    .home-hero__inner {
      grid-template-columns: minmax(0, 0.95fr) minmax(28rem, 1.05fr);
    }
  }

  @media (max-width: 720px) {
    .home-hero {
      min-height: auto;
      padding-block: var(--site-space-7);
    }

    .home-hero__inner,
    .home-hero__content {
      gap: var(--site-space-5);
    }

    .home-hero__eyebrow {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--site-space-2);
    }

    .home-hero__eyebrow-dot {
      display: none;
    }

    .home-hero__diagram {
      padding: var(--site-space-3);
    }
  }
</style>
