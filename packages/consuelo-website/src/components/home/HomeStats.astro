---
import { homeMetrics, homeStats } from '../../data/home-content';

type Props = {
  sectionId?: string;
};

const { sectionId } = Astro.props as Props;

// 1. Joyplot (Multi-line)
const numLines = 28;
const joyplotLines = Array.from({ length: numLines }).map((_, i) => {
  const progress = i / (numLines - 1);
  const baseOffset = progress * 90; // vertical spread
  let points = [];
  for (let x = 10; x <= 170; x += 2) {
    // Mountain shape towards the right
    const peak = 60 * Math.exp(-Math.pow(x - 120, 2) / 600);
    const secondaryPeak = 25 * Math.exp(-Math.pow(x - 80, 2) / 800);
    const noise = Math.sin(x * 0.15 + i) * 1.5;
    
    // Scale down peaks for front lines
    const scale = 1 - (progress * 0.3);
    
    const y = 135 - baseOffset - ((peak + secondaryPeak) * scale) + noise;
    points.push(`${x},${y.toFixed(2)}`);
  }
  // Fade out back lines
  const opacity = 0.15 + (1 - progress) * 0.7;
  return { points: points.join(' '), opacity };
});

// 2. Heatmap (Squares)
const cols = 23;
const rows = 18;
const squares: { x: number; y: number; opacity: number }[] = [];
for (let row = 0; row < rows; row++) {
  for (let col = 0; col < cols; col++) {
    const x = 11 + col * 7;
    const y = 16 + row * 7;
    
    // Pseudo-random opacity based on coordinates
    const hash = Math.sin(row * 12.9898 + col * 78.233) * 43758.5453;
    let rawOpacity = Math.abs(hash - Math.floor(hash));
    
    // Create clustering/heatmap effect (more dense in center)
    const distFromCenter = Math.sqrt(Math.pow(col - 11, 2) + Math.pow(row - 8.5, 2));
    const centerBoost = Math.max(0, 1 - distFromCenter / 12);
    rawOpacity = (rawOpacity + centerBoost) / 2;
    
    let opacity = 0.05;
    if (rawOpacity > 0.7) opacity = 0.8;
    else if (rawOpacity > 0.4) opacity = 0.4;
    else opacity = 0.1;
    
    squares.push({ x, y, opacity });
  }
}

// 3. Thin Bars
const numBars = 55;
const thinBars = Array.from({ length: numBars }).map((_, i) => {
  const x = 10 + i * 3;
  
  // Pseudo-random height
  const hash = Math.sin(i * 12.9898) * 43758.5453;
  const rand = Math.abs(hash - Math.floor(hash));
  
  // Bell curve shape
  const bell = Math.sin((i / (numBars - 1)) * Math.PI);
  
  const height = 20 + bell * 60 + rand * 45;
  const y = 135 - height;
  
  const opacity = 0.2 + rand * 0.6;
  
  return { x, y, height, opacity };
});
---

<section class="launch-section" id={sectionId} data-motion-section="proof-svg">
  <div class="launch-content launch-content--wide launch-stats">
    <div class="launch-stats__intro">
      <p class="launch-eyebrow">{homeStats.eyebrow}</p>
      <h2 class="launch-stats__title">{homeStats.title}</h2>
      {homeStats.intro && <p class="launch-copy">{homeStats.intro}</p>}
    </div>

    <div class="launch-stats__grid">
      {homeMetrics.map((metric, index) => (
        <article class="launch-stats__metric">
          <div class="launch-stats__chart" aria-hidden="true" data-motion="svg-grid" data-motion-chart={metric.chart}>
            {metric.chart === 'line' && (
              <svg viewBox="0 0 180 140" role="presentation" data-motion="svg-grid">
                {joyplotLines.map((line) => (
                  <polyline points={line.points} data-motion="svg-path" data-motion-opacity={line.opacity} style={`opacity: ${line.opacity}`} />
                ))}
              </svg>
            )}

            {metric.chart === 'dots' && (
              <svg viewBox="0 0 180 140" role="presentation" data-motion="svg-grid" data-motion-grid="heatmap" data-motion-columns={cols} data-motion-rows={rows}>
                {squares.map((sq, squareIndex) => (
                  <rect x={sq.x} y={sq.y} width="4" height="4" class="is-filled" data-motion="svg-square" data-motion-index={squareIndex} data-motion-opacity={sq.opacity} style={`opacity: ${sq.opacity}`} />
                ))}
              </svg>
            )}

            {metric.chart === 'bars' && (
              <svg viewBox="0 0 180 140" role="presentation" data-motion="svg-grid">
                {thinBars.map((bar) => (
                  <rect x={bar.x} y={bar.y} width="1" height={bar.height} class="is-filled" data-motion="svg-bar" data-motion-opacity={bar.opacity} style={`opacity: ${bar.opacity}`} />
                ))}
              </svg>
            )}
          </div>

          <p class="launch-stats__caption launch-mono">
            Fig {index + 1}. <strong class="launch-stats__value">{metric.value}</strong> <span class="launch-stats__label-text">{metric.label}</span>
          </p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .launch-stats {
    display: grid;
    gap: 1.35rem;
  }

  .launch-stats__intro {
    display: grid;
    gap: 0.85rem;
    max-width: 58rem;
  }

  .launch-stats__title {
    margin: 0;
    font-size: clamp(0.88rem, 0.82rem + 0.2vw, 0.95rem);
    line-height: 1.08;
    letter-spacing: -0.06em;
    color: var(--launch-muted);
  }

  .launch-stats__grid {
    display: grid;
    gap: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--launch-line);
    margin-top: 1.5rem;
  }

  .launch-stats__metric {
    display: grid;
    gap: 1.2rem;
  }

  .launch-stats__chart {
    min-height: 10rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .launch-stats__chart svg {
    width: 100%;
    height: 100%;
    color: var(--launch-muted);
  }

  .launch-stats__chart polyline {
    fill: none;
    stroke: currentColor;
    stroke-width: 0.75;
  }

  .launch-stats__chart rect.is-filled {
    fill: currentColor;
    stroke: none;
  }

  .launch-stats__caption {
    margin: 0;
    font-size: 0.76rem;
    color: var(--launch-muted);
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .launch-stats__value {
    color: var(--launch-fg);
    font-weight: 600;
  }
  
  .launch-stats__label-text {
    text-transform: capitalize;
  }

  @media (min-width: 980px) {
    .launch-stats__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 2rem;
      border-top: 0;
      margin-top: 0;
      padding-top: 0;
    }
  }
  .launch-stats__chart [data-motion="svg-bar"] {
    transform-box: fill-box;
    transform-origin: 50% 100%;
  }

  .launch-stats__chart [data-motion="svg-square"] {
    transform-box: fill-box;
    transform-origin: 50% 50%;
  }

</style>
