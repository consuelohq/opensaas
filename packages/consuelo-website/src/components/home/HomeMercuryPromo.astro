---
import { homeMercuryPromo } from '../../data/home-content';

type Props = {
  sectionId?: string;
};

const { sectionId } = Astro.props as Props;

const icons = [
  { src: '/icons/twilio.svg', alt: 'Twilio' },
  { src: '/icons/anthropic.svg', alt: 'Anthropic' },
  { src: '/icons/openai.svg', alt: 'OpenAI' },
  { src: '/icons/groq.svg', alt: 'Groq' },
  { src: '/icons/railway.svg', alt: 'Railway' },
];
---

<section class="launch-section" id={sectionId}>
  <div class="launch-content launch-content--wide launch-mercury-promo">
    <h2 class="launch-mono">{homeMercuryPromo.title}</h2>
    <p class="launch-copy">{homeMercuryPromo.intro}</p>
    <div class="launch-mercury-promo__icons">
      {icons.map((icon) => (
        <img src={icon.src} alt={icon.alt} width="24" height="24" class="launch-mercury-promo__icon" />
      ))}
    </div>
    <a class="launch-mercury-promo__link launch-mono" href={homeMercuryPromo.primaryHref}>
      {homeMercuryPromo.primaryLabel} ↗
    </a>
  </div>
</section>

<style>
  .launch-mercury-promo {
    display: grid;
    gap: 1rem;
  }

  .launch-mercury-promo h2 {
    margin: 0;
    font-size: clamp(1.25rem, 1rem + 0.8vw, 1.6rem);
    letter-spacing: -0.04em;
    line-height: 1.15;
  }

  .launch-mercury-promo__icons {
    display: flex;
    gap: 1rem;
    align-items: center;
    padding-top: 0.25rem;
  }

  .launch-mercury-promo__icon {
    width: 1.25rem;
    height: 1.25rem;
    opacity: 0.7;
    filter: var(--launch-icon-filter, none);
  }

  @media (prefers-color-scheme: dark) {
    .launch-mercury-promo__icon {
      filter: invert(1);
    }
  }

  .launch-mercury-promo__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.82rem;
    color: var(--launch-fg);
    text-decoration: none;
    border: 1px solid var(--launch-line);
    padding: 0.5rem 1rem;
    width: fit-content;
    transition: border-color 0.15s;
  }

  .launch-mercury-promo__link:hover {
    border-color: var(--launch-fg);
  }
</style>
