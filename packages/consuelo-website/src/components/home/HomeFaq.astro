---
import { homeFaq } from '../../data/home-content';
import type { HomeFaqItem } from '../../data/home-content';

type Props = {
  sectionId?: string;
  title?: string;
  intro?: string;
  items: HomeFaqItem[];
};

const {
  sectionId,
  title = homeFaq.title,
  intro = homeFaq.intro,
  items,
} = Astro.props as Props;
---

<section class="launch-section" id={sectionId}>
  <div class="launch-content launch-content--wide launch-faq">
    <div class="launch-faq__intro">
      <p class="launch-eyebrow">{homeFaq.eyebrow}</p>
      <h2>{title}</h2>
      {intro && <p class="launch-copy">{intro}</p>}
    </div>

    <div class="launch-faq__list">
      {items.map((item) => (
        <details class="launch-faq__item">
          <summary>
            <span class="launch-faq__icon" aria-hidden="true">
              <span></span>
              <span></span>
            </span>
            <span>{item.question}</span>
          </summary>
          <p class="launch-copy" set:html={item.answer} />
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .launch-faq {
    display: grid;
    gap: 1.35rem;
  }

  .launch-faq h2 {
    margin: 0;
    font-size: clamp(0.88rem, 0.82rem + 0.2vw, 0.95rem);
    letter-spacing: -0.06em;
    line-height: 1.06;
    color: var(--launch-muted);
  }

  .launch-faq__intro {
    display: grid;
    gap: 0.9rem;
    max-width: 46rem;
  }

  .launch-faq__list {
    display: grid;
    gap: 0.2rem;
  }

  .launch-faq__item {
    padding: 0.05rem 0;
  }

  .launch-faq__item summary {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.75rem;
    align-items: center;
    padding: 0.7rem 0;
    list-style: none;
    font-size: 0.82rem;
    color: var(--launch-fg);
  }

  .launch-faq__item summary::-webkit-details-marker {
    display: none;
  }

  .launch-faq__item p {
    padding: 0 0 0.85rem 1.65rem;
    max-width: 48rem;
  }

  .launch-faq__icon {
    position: relative;
    width: 0.72rem;
    height: 0.72rem;
    color: var(--launch-muted);
    flex: 0 0 auto;
  }

  .launch-faq__icon span {
    position: absolute;
    inset: 50% auto auto 50%;
    width: 0.72rem;
    height: 1px;
    background: currentColor;
    transform: translate(-50%, -50%);
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .launch-faq__icon span:last-child {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .launch-faq__item[open] .launch-faq__icon span:last-child {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(90deg) scaleX(0.2);
  }
</style>
