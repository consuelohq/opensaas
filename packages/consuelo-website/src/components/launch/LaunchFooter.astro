---
import {
  footerLinks,
  launchFooterSignup,
  siteLinks,
} from '../../data/launch-content';

type Props = {
  sectionId?: string;
};

const { sectionId } = Astro.props as Props;
---

<section class="launch-section" id={sectionId}>
  <div class="launch-content launch-content--wide launch-footer-signup">
    <div class="launch-footer-signup__intro">
      <p class="launch-eyebrow">{launchFooterSignup.eyebrow}</p>
      <h2>{launchFooterSignup.title}</h2>
      <p class="launch-copy">{launchFooterSignup.intro}</p>
    </div>

    <form class="launch-footer-signup__form" data-newsletter-form>
      <div class="launch-footer-signup__field">
        <input aria-label="Email address" name="email" placeholder="Email address" type="email" />
        <button class="launch-button launch-mono" type="submit">{launchFooterSignup.buttonLabel}</button>
      </div>
    </form>
  </div>
</section>

<footer class="launch-section">
  <div class="launch-content launch-content--wide launch-footer-links launch-mono">
    {footerLinks.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
  </div>
  <div class="launch-content launch-content--wide launch-footer-meta launch-mono">
    <span>©2026 consuelo</span>
    <div>
      <a href={siteLinks.privacy}>privacy</a>
      <a href={siteLinks.terms}>terms</a>
      <a href={siteLinks.docs}>docs</a>
    </div>
  </div>
</footer>

<script define:vars={{ siteLinks }}>
  const form = document.querySelector('[data-newsletter-form]');
  if (form instanceof HTMLFormElement) {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const input = form.querySelector('input[name="email"]');
      const email = input instanceof HTMLInputElement ? input.value.trim() : '';
      const base = siteLinks.newsletter;
      const separator = base.includes('?') ? '&' : '?';
      const body = email ? 'body=' + encodeURIComponent('newsletter: ' + email) : '';
      window.location.href = body ? base + separator + body : base;
    });
  }
</script>

<style>
  .launch-footer-signup {
    display: grid;
    gap: 1.2rem;
  }

  .launch-footer-signup__intro {
    display: grid;
    gap: 0.95rem;
    max-width: 32rem;
  }

  .launch-footer-signup h2 {
    margin: 0;
    font-size: clamp(1.9rem, 1.35rem + 1.4vw, 3rem);
    letter-spacing: -0.07em;
    line-height: 1.02;
  }

  .launch-footer-signup__form {
    display: grid;
    gap: 0.75rem;
  }

  .launch-footer-signup__field {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    border: 1px solid var(--launch-line);
    background: var(--launch-panel);
  }

  .launch-footer-signup__field input {
    width: 100%;
    min-height: 3rem;
    padding: 0 1rem;
    background: transparent;
    color: var(--launch-fg);
    border: 0;
  }

  .launch-footer-signup__field .launch-button {
    margin: 0.28rem;
    min-height: 2.45rem;
  }

  .launch-footer-links {
    display: grid;
    gap: 0;
  }

  .launch-footer-links a,
  .launch-footer-meta a,
  .launch-footer-meta span {
    padding: 0.95rem 0;
    color: var(--launch-muted);
    font-size: 0.8rem;
  }

  .launch-footer-links a + a {
    border-top: 1px solid var(--launch-line);
  }

  .launch-footer-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid var(--launch-line);
  }

  .launch-footer-meta div {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  @media (min-width: 860px) {
    .launch-footer-signup {
      grid-template-columns: minmax(0, 1fr) minmax(20rem, 32rem);
      align-items: end;
      gap: 1.5rem;
    }

    .launch-footer-links {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .launch-footer-links a + a {
      border-top: 0;
      border-left: 1px solid var(--launch-line);
      padding-left: 1rem;
    }
  }

  @media (max-width: 640px) {
    .launch-footer-signup__field {
      grid-template-columns: minmax(0, 1fr);
    }

    .launch-footer-signup__field .launch-button {
      width: calc(100% - 0.56rem);
    }
  }
</style>
