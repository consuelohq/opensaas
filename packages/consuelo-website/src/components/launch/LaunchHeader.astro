---
import {
  launchHeaderLinks,
  launchMobileMenuLinks,
  siteLinks,
} from '../../data/launch-content';
import { launchDocsMenuTabs } from '../../data/launch-docs';

type Props = {
  pageSections?: LaunchPageSection[];
};

type LaunchPageSection = {
  id: string;
  label: string;
};

const { pageSections = [] } = Astro.props as Props;
const hasPageSections = pageSections.length > 0;
---

<header class="launch-header launch-section" data-launch-header>
  <div class="launch-content launch-content--wide launch-header__inner">
    <a class="launch-header__brand launch-mono" href="/">consuelo.</a>

    <div class="launch-header__desktop">
      <nav class="launch-header__nav launch-mono" aria-label="Primary">
        {launchHeaderLinks.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </nav>

      <div class="launch-header__actions launch-mono">
        <a class="launch-header__login" href={siteLinks.login}>login</a>
        <a class="launch-button" href={siteLinks.free}>free</a>
      </div>
    </div>

    <button
      class="launch-header__menu-toggle"
      type="button"
      aria-controls="launch-mobile-menu"
      aria-expanded="false"
      data-mobile-menu-toggle
    >
      <span class="sr-only">open menu</span>
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path class="launch-header__menu-line launch-header__menu-line--top" d="M4 7H20" />
        <path class="launch-header__menu-line launch-header__menu-line--middle" d="M4 12H20" />
        <path class="launch-header__menu-line launch-header__menu-line--bottom" d="M4 17H20" />
      </svg>
    </button>
  </div>

  {hasPageSections && (
    <div class="launch-header__page-nav launch-mono" data-page-nav>
      <button
        class="launch-header__page-nav-toggle"
        type="button"
        aria-controls="launch-page-nav-panel"
        aria-expanded="false"
        data-page-nav-toggle
      >
        <span class="launch-header__page-nav-kicker">on this page</span>
        <span class="launch-header__page-nav-active" data-active-section-label>
          {pageSections[0].label}
        </span>
      </button>

      <div
        class="launch-header__page-nav-panel"
        id="launch-page-nav-panel"
        data-page-nav-panel
        data-open="false"
      >
        {pageSections.map((section) => (
          <a class="launch-header__page-link" href={
            '#' + section.id
          } data-page-anchor>
            {section.label}
          </a>
        ))}
      </div>
    </div>
  )}
</header>

<div class="launch-header__mobile-menu" data-mobile-menu data-open="false" aria-hidden="true" id="launch-mobile-menu">
  <button class="launch-header__mobile-backdrop" type="button" aria-label="close menu" data-mobile-menu-close></button>

  <div class="launch-header__mobile-panel">
    <div class="launch-header__mobile-top launch-mono">
      <a class="launch-header__brand" href="/">consuelo.</a>
      <button class="launch-header__mobile-close" type="button" data-mobile-menu-close>
        <span class="sr-only">close menu</span>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 6L18 18" />
          <path d="M18 6L6 18" />
        </svg>
      </button>
    </div>

    <div class="launch-header__mobile-scroll launch-mono">
      <section class="launch-header__mobile-section">
        <p class="launch-eyebrow">menu</p>
        <div class="launch-header__mobile-links">
          {launchMobileMenuLinks.map((link) => (
            <a href={link.href} data-mobile-link>{link.label}</a>
          ))}
        </div>
      </section>

      {hasPageSections && (
        <section class="launch-header__mobile-section">
          <p class="launch-eyebrow">landing page</p>
          <div class="launch-header__mobile-links">
            {pageSections.map((section) => (
              <a href={
                '#' + section.id
              } data-mobile-link>{section.label}</a>
            ))}
          </div>
        </section>
      )}

      <section class="launch-header__mobile-section">
        <p class="launch-eyebrow">docs</p>

        <div class="launch-header__docs-tabs">
          {launchDocsMenuTabs.map((tab) => (
            <section class="launch-header__docs-tab">
              <p class="launch-header__docs-tab-title">{tab.label}</p>

              <div class="launch-header__docs-groups">
                {tab.groups.map((group) => (
                  <details class="launch-header__docs-group">
                    <summary>
                      <span>{group.label}</span>
                      <span class="launch-header__summary-icon" aria-hidden="true">
                        <span></span>
                        <span></span>
                      </span>
                    </summary>

                    <div class="launch-header__docs-links">
                      {group.links.map((link) => (
                        <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
                      ))}
                    </div>
                  </details>
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>
    </div>
  </div>
</div>

<script define:vars={{ pageSections }}>
  const header = document.querySelector('[data-launch-header]');
  const menu = document.querySelector('[data-mobile-menu]');
  const menuToggle = document.querySelector('[data-mobile-menu-toggle]');
  const menuCloseButtons = Array.from(
    document.querySelectorAll('[data-mobile-menu-close]'),
  );
  const pageNav = document.querySelector('[data-page-nav]');
  const pageNavToggle = document.querySelector('[data-page-nav-toggle]');
  const pageNavPanel = document.querySelector('[data-page-nav-panel]');
  const activeSectionLabel = document.querySelector('[data-active-section-label]');
  const pageAnchors = Array.from(document.querySelectorAll('[data-page-anchor]'));
  const mobileLinks = Array.from(document.querySelectorAll('[data-mobile-link]'));

  const setMenuOpen = (nextOpen) => {
    if (!(menu instanceof HTMLElement) || !(menuToggle instanceof HTMLButtonElement)) {
      return;
    }

    menu.dataset.open = nextOpen ? 'true' : 'false';
    menu.setAttribute('aria-hidden', nextOpen ? 'false' : 'true');
    menuToggle.dataset.open = nextOpen ? 'true' : 'false';
    menuToggle.setAttribute('aria-expanded', nextOpen ? 'true' : 'false');
    document.body.style.overflow = nextOpen ? 'hidden' : '';
  };

  const setPageNavOpen = (nextOpen) => {
    if (!(pageNavPanel instanceof HTMLElement) || !(pageNavToggle instanceof HTMLButtonElement)) {
      return;
    }

    pageNavPanel.dataset.open = nextOpen ? 'true' : 'false';
    pageNavToggle.setAttribute('aria-expanded', nextOpen ? 'true' : 'false');
  };

  const syncActiveSection = (sectionId) => {
    const activeSection = pageSections.find((section) => section.id === sectionId);

    if (!activeSection) {
      return;
    }

    if (activeSectionLabel instanceof HTMLElement) {
      activeSectionLabel.textContent = activeSection.label;
    }

    pageAnchors.forEach((anchor) => {
      if (!(anchor instanceof HTMLAnchorElement)) {
        return;
      }

      const isActive = anchor.getAttribute('href') === '#' + sectionId;
      anchor.classList.toggle('is-active', isActive);
      anchor.setAttribute('aria-current', isActive ? 'location' : 'false');
    });
  };

  if (menuToggle instanceof HTMLButtonElement) {
    menuToggle.addEventListener('click', () => {
      const isOpen = menu instanceof HTMLElement && menu.dataset.open === 'true';
      setMenuOpen(!isOpen);
    });
  }

  menuCloseButtons.forEach((button) => {
    if (!(button instanceof HTMLButtonElement)) {
      return;
    }

    button.addEventListener('click', () => {
      setMenuOpen(false);
    });
  });

  mobileLinks.forEach((link) => {
    if (!(link instanceof HTMLAnchorElement)) {
      return;
    }

    link.addEventListener('click', () => {
      setMenuOpen(false);
      setPageNavOpen(false);
    });
  });

  if (pageNavToggle instanceof HTMLButtonElement) {
    pageNavToggle.addEventListener('click', () => {
      const isOpen = pageNavPanel instanceof HTMLElement && pageNavPanel.dataset.open === 'true';
      setPageNavOpen(!isOpen);
    });
  }

  if (pageSections.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        const visibleEntries = entries
          .filter((entry) => entry.isIntersecting)
          .sort((entryA, entryB) => entryB.intersectionRatio - entryA.intersectionRatio);

        const nextSection = visibleEntries[0];

        if (nextSection) {
          syncActiveSection(nextSection.target.id);
        }
      },
      {
        rootMargin: '-18% 0px -55% 0px',
        threshold: [0.2, 0.45, 0.7],
      },
    );

    pageSections.forEach((section) => {
      const element = document.getElementById(section.id);

      if (element) {
        observer.observe(element);
      }
    });

    syncActiveSection(pageSections[0].id);
  }

  const syncHeaderState = () => {
    if (!(header instanceof HTMLElement)) {
      return;
    }

    header.classList.toggle('is-scrolled', window.scrollY > 24);
  };

  syncHeaderState();
  window.addEventListener('scroll', syncHeaderState, { passive: true });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      setMenuOpen(false);
      setPageNavOpen(false);
    }
  });

  document.addEventListener('click', (event) => {
    if (
      pageNav instanceof HTMLElement &&
      pageNavPanel instanceof HTMLElement &&
      pageNavPanel.dataset.open === 'true' &&
      !pageNav.contains(event.target)
    ) {
      setPageNavOpen(false);
    }
  });
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .launch-header {
    position: sticky;
    top: 0;
    z-index: 40;
    backdrop-filter: blur(16px);
    background: color-mix(in srgb, var(--launch-bg) 88%, transparent);
    transition: background 180ms ease, border-color 180ms ease;
  }

  .launch-header.is-scrolled {
    background: color-mix(in srgb, var(--launch-bg) 94%, transparent);
  }

  .launch-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
    min-height: 4.25rem;
  }

  .launch-header__brand {
    font-size: 1.55rem;
    font-weight: 700;
    letter-spacing: -0.08em;
  }

  .launch-header__desktop {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 1.15rem;
  }

  .launch-header__nav {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    color: var(--launch-muted);
    font-size: 0.84rem;
  }

  .launch-header__nav a:hover,
  .launch-header__docs-links a:hover,
  .launch-header__mobile-links a:hover {
    color: var(--launch-fg);
  }

  .launch-header__actions {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .launch-header__login {
    font-size: 0.84rem;
    color: var(--launch-muted);
  }

  .launch-header__menu-toggle,
  .launch-header__page-nav {
    display: none;
  }

  .launch-header__menu-toggle,
  .launch-header__mobile-close {
    width: 2.4rem;
    height: 2.4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: transparent;
    color: var(--launch-fg);
  }

  .launch-header__menu-toggle svg,
  .launch-header__mobile-close svg {
    width: 1.2rem;
    height: 1.2rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.6;
    stroke-linecap: square;
    stroke-linejoin: miter;
  }

  .launch-header__menu-line {
    transform-origin: center;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .launch-header__menu-toggle[data-open='true'] .launch-header__menu-line--top {
    transform: translateY(5px) rotate(45deg);
  }

  .launch-header__menu-toggle[data-open='true'] .launch-header__menu-line--middle {
    opacity: 0;
  }

  .launch-header__menu-toggle[data-open='true'] .launch-header__menu-line--bottom {
    transform: translateY(-5px) rotate(-45deg);
  }

  .launch-header__page-nav {
    position: relative;
    border-top: 1px solid var(--launch-line);
  }

  .launch-header__page-nav-toggle {
    width: 100%;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: center;
    padding: 0.85rem 1rem;
    background: transparent;
    border: 0;
    color: inherit;
    text-align: left;
  }

  .launch-header__page-nav-kicker {
    color: var(--launch-muted);
    font-size: 0.78rem;
  }

  .launch-header__page-nav-active {
    justify-self: end;
    font-size: 0.8rem;
  }

  .launch-header__page-nav-panel {
    position: absolute;
    inset: calc(100% + 0.4rem) 1rem auto;
    border: 1px solid var(--launch-line);
    background: var(--launch-panel);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-0.35rem);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .launch-header__page-nav-panel[data-open='true'] {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .launch-header__page-link {
    display: block;
    padding: 0.85rem 1rem;
    border-top: 1px solid var(--launch-line);
    color: var(--launch-muted);
    font-size: 0.8rem;
  }

  .launch-header__page-link:first-child {
    border-top: 0;
  }

  .launch-header__page-link.is-active {
    color: var(--launch-fg);
  }

  .launch-header__mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 50;
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease;
  }

  .launch-header__mobile-menu[data-open='true'] {
    opacity: 1;
    pointer-events: auto;
  }

  .launch-header__mobile-backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    background: rgba(0, 0, 0, 0.55);
  }

  .launch-header__mobile-panel {
    position: absolute;
    inset: 0 0 0 auto;
    width: min(100%, 28rem);
    background: var(--launch-bg);
    border-left: 1px solid var(--launch-line);
    transform: translateX(100%);
    transition: transform 220ms ease;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
  }

  .launch-header__mobile-menu[data-open='true'] .launch-header__mobile-panel {
    transform: translateX(0);
  }

  .launch-header__mobile-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
    border-bottom: 1px solid var(--launch-line);
  }

  .launch-header__mobile-scroll {
    overflow-y: auto;
    padding: 1rem;
    display: grid;
    gap: 1.35rem;
  }

  .launch-header__mobile-section,
  .launch-header__docs-tab {
    display: grid;
    gap: 0.8rem;
  }

  .launch-header__mobile-links {
    display: grid;
    border: 1px solid var(--launch-line);
    background: var(--launch-panel);
  }

  .launch-header__mobile-links a,
  .launch-header__docs-links a {
    padding: 0.9rem 1rem;
    border-top: 1px solid var(--launch-line);
    font-size: 0.82rem;
    color: var(--launch-muted);
  }

  .launch-header__mobile-links a:first-child,
  .launch-header__docs-links a:first-child {
    border-top: 0;
  }

  .launch-header__docs-tabs,
  .launch-header__docs-groups {
    display: grid;
    gap: 0.75rem;
  }

  .launch-header__docs-tab-title {
    margin: 0;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--launch-muted);
  }

  .launch-header__docs-group {
    border: 1px solid var(--launch-line);
    background: var(--launch-panel);
    overflow: hidden;
  }

  .launch-header__docs-group summary {
    list-style: none;
    cursor: pointer;
    padding: 0.9rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.82rem;
  }

  .launch-header__docs-group summary::-webkit-details-marker {
    display: none;
  }

  .launch-header__summary-icon {
    position: relative;
    width: 0.8rem;
    height: 0.8rem;
    flex: 0 0 auto;
  }

  .launch-header__summary-icon span {
    position: absolute;
    inset: 50% auto auto 50%;
    width: 0.8rem;
    height: 1px;
    background: currentColor;
    transform: translate(-50%, -50%);
    transition: transform 160ms ease, opacity 160ms ease;
  }

  .launch-header__summary-icon span:last-child {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .launch-header__docs-group[open] .launch-header__summary-icon span:last-child {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(90deg) scaleX(0.2);
  }

  .launch-header__docs-links {
    display: grid;
    border-top: 1px solid var(--launch-line);
  }

  @media (max-width: 820px) {
    .launch-header__desktop {
      display: none;
    }

    .launch-header__menu-toggle,
    .launch-header__page-nav {
      display: inline-flex;
    }

    .launch-header__inner {
      grid-template-columns: auto 1fr auto;
    }

    .launch-header__menu-toggle {
      justify-self: end;
    }
  }
</style>
