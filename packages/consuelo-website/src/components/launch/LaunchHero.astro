---
import {
  launchAnnouncement,
  launchHero,
  launchTabs,
} from '../../data/launch-content';

type Props = {
  sectionId?: string;
};

const { sectionId } = Astro.props as Props;
---

<section class="launch-section" id={sectionId} data-motion="section-reveal">
  <div class="launch-content launch-content--wide launch-hero">
    <a href={launchAnnouncement.linkHref} class="launch-hero__announcement launch-mono" data-motion="hero-eyebrow">
      <span class="launch-hero__badge">{launchAnnouncement.badge}</span>
      <span class="launch-hero__announcement-text">
        {launchAnnouncement.text} <span class="launch-inline-link">{launchAnnouncement.linkLabel}</span>
      </span>
    </a>

    <div class="launch-hero__copy">
      <h1 class="launch-title" data-motion="hero-line">{launchHero.title}</h1>
      <p class="launch-copy" data-motion="hero-copy">{launchHero.description}</p>
    </div>

    <div class="launch-hero__snippet launch-card" data-launch-hero data-motion="hero-demo">
      <div class="launch-hero__tabs launch-mono" role="tablist" aria-label="Consuelo surfaces" data-motion="hero-tabs">
        {launchTabs.map((tab, index) => (
          <button
            class:list={['launch-hero__tab', { 'is-active': index === 0 }]}
            type="button"
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            data-tab-button={tab.id}
            data-motion="tab"
          >
            {tab.label}
          </button>
        ))}
      </div>

      <div class="launch-hero__snippet-panels">
        {launchTabs.map((tab, index) => tab.kind === 'link' && tab.href ? (
          <a
            href={tab.href}
            class:list={['launch-hero__snippet-panel', { 'is-active': index === 0 }]}
            data-tab-panel={tab.id}
            data-motion="tab-panel"
          >
            <span class="launch-hero__snippet-value launch-mono">{tab.value}</span>
            <span class="launch-hero__snippet-action" aria-hidden="true">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M7 17L17 7" />
                <path d="M7 7h10v10" />
              </svg>
            </span>
          </a>
        ) : (
          <div 
            class:list={['launch-hero__snippet-panel', { 'is-active': index === 0 }]} 
            data-tab-panel={tab.id}
            data-copy-button={tab.id}
            data-motion="tab-panel"
          >
            <code class="launch-hero__snippet-value launch-mono">{tab.value}</code>
            <span class="launch-hero__snippet-action" aria-hidden="true">
              <svg class="launch-hero__copy-icon" viewBox="0 0 24 24" aria-hidden="true">
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
              </svg>
              <svg class="launch-hero__check-icon" viewBox="0 0 24 24" aria-hidden="true">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </span>
          </div>
        ))}
      </div>
    </div>

    <div class="launch-hero__media" data-launch-media data-motion="hero-media">
      {launchTabs.map((tab, index) => (
        <figure class:list={['launch-hero__media-panel', { 'is-active': index === 0 }]} data-media-panel={tab.id} data-motion="media-panel">
          <picture>
            {tab.darkImageSrc && <source data-deferred-source data-srcset={tab.darkImageSrc} media="(prefers-color-scheme: dark)" />}
            <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==" data-deferred-media data-src={tab.imageSrc} alt={tab.imageAlt} loading="lazy" decoding="async" />
          </picture>
        </figure>
      ))}
    </div>
  </div>
</section>

<script define:vars={{ launchTabs }}>
  const root = document.querySelector('[data-launch-hero]');
  const mediaRoot = document.querySelector('[data-launch-media]');

  if (root instanceof HTMLElement && mediaRoot instanceof HTMLElement) {
    const buttons = Array.from(root.querySelectorAll('[data-tab-button]'));
    const panels = Array.from(root.querySelectorAll('[data-tab-panel]'));
    const mediaPanels = Array.from(mediaRoot.querySelectorAll('[data-media-panel]'));
    const copyButtons = Array.from(root.querySelectorAll('[data-copy-button]'));
    let activeIndex = 0;

    const sync = (nextIndex) => {
      activeIndex = nextIndex;
      buttons.forEach((button, index) => {
        const isActive = index === nextIndex;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      panels.forEach((panel, index) => panel.classList.toggle('is-active', index === nextIndex));
      mediaPanels.forEach((panel, index) => panel.classList.toggle('is-active', index === nextIndex));
      document.dispatchEvent(new CustomEvent('launch:hero-tab-change', { detail: { activeIndex: nextIndex } }));
    };

    buttons.forEach((button, index) => {
      button.addEventListener('click', () => {
        sync(index);
      });
    });

    copyButtons.forEach((button) => {
      button.addEventListener('click', async () => {
        const tabId = button.getAttribute('data-copy-button');
        const entry = launchTabs.find((tab) => tab.id === tabId);

        if (!entry) {
          return;
        }

        await navigator.clipboard.writeText(entry.value);
        button.classList.add('is-copied');
        window.setTimeout(() => {
          button.classList.remove('is-copied');
        }, 1400);
      });
    });

    sync(0);
  }
</script>

<style>
  .launch-hero {
    display: grid;
    gap: 1.25rem;
    padding-top: clamp(2rem, 1.5rem + 2vw, 3.5rem);
    padding-bottom: clamp(2rem, 1.5rem + 2vw, 3.5rem);
  }

  .launch-hero__announcement {
    display: inline-flex;
    text-decoration: none;
    width: fit-content;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    color: var(--launch-muted);
    font-size: 0.78rem;
  }

  .launch-hero__badge {
    border: 1px solid color-mix(in srgb, var(--launch-line) 40%, transparent);
    padding: 0.08rem 0.28rem;
    color: var(--launch-fg);
    background: var(--launch-panel);
    transition: border-color 160ms ease;
  }

  .launch-hero__announcement:hover .launch-hero__badge {
    border-color: var(--launch-line);
  }

  .launch-hero__copy {
    display: grid;
    gap: 0.85rem;
    max-width: 37rem;
  }

  .launch-hero__snippet {
    overflow: hidden;
  }

  .launch-hero__tabs {
    display: flex;
    gap: 0.15rem;
    overflow-x: auto;
    overflow-y: hidden;
    overscroll-behavior-x: contain;
    overscroll-behavior-y: none;
    touch-action: pan-x;
    -webkit-overflow-scrolling: touch;
    border-bottom: 1px solid var(--launch-line);
    padding: 0.15rem 0.28rem 0;
    scrollbar-width: none;
  }

  .launch-hero__tabs::-webkit-scrollbar {
    display: none;
  }

  .launch-hero__tab {
    border: 0;
    background: transparent;
    color: var(--launch-muted);
    padding: 0.45rem 0.78rem;
    white-space: nowrap;
    font-size: 0.88rem;
    outline: none;
  }
  
  .launch-hero__tab:focus {
    outline: none !important;
    box-shadow: none !important;
  }
  
  .launch-hero__tab:focus-visible {
    outline: none !important;
    box-shadow: none !important;
  }

  .launch-hero__tab.is-active {
    background: transparent;
    color: var(--launch-fg);
    border-bottom: 2px dotted var(--launch-fg);
    margin-bottom: -1px;
  }

  .launch-hero__snippet-panels {
    background: var(--launch-panel);
  }

  .launch-hero__snippet-panel {
    display: none;
    align-items: center;
    justify-content: flex-start;
    gap: 0.75rem;
    padding: 0.6rem 0.85rem;
    cursor: pointer;
    transition: background 160ms ease;
    text-decoration: none;
  }

  .launch-hero__snippet-panel.is-active {
    display: flex;
  }

  .launch-hero__snippet-panel:hover {
    background: color-mix(in srgb, var(--launch-fg) 3%, transparent);
  }

  .launch-hero__snippet-panel:hover .launch-hero__snippet-action {
    color: var(--launch-fg);
    background: color-mix(in srgb, var(--launch-fg) 8%, transparent);
  }

  .launch-hero__snippet-value {
    margin: 0;
    min-width: 0;
    display: block;
    color: var(--launch-fg);
    font-size: 0.72rem;
    line-height: 1.5;
    overflow-wrap: anywhere;
  }

  .launch-hero__snippet-action {
    width: 1.6rem;
    height: 1.6rem;
    border: none;
    border-radius: 0.35rem;
    background: transparent;
    color: var(--launch-muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 160ms ease, background 160ms ease;
  }

  .launch-hero__snippet-action svg {
    width: 0.96rem;
    height: 0.96rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .launch-hero__check-icon {
    display: none;
  }

  .launch-hero__snippet-panel.is-copied .launch-hero__snippet-action {
    color: var(--launch-success);
  }

  .launch-hero__snippet-panel.is-copied .launch-hero__copy-icon {
    display: none;
  }

  .launch-hero__snippet-panel.is-copied .launch-hero__check-icon {
    display: block;
  }

  .launch-hero__media {
    position: relative;
    overflow: hidden;
    border: 0;
    background: transparent;
    aspect-ratio: 16 / 9;
  }

  .launch-hero__media-panel {
    display: none;
    margin: 0;
    height: 100%;
    background: transparent;
  }

  .launch-hero__media-panel.is-active {
    display: block;
    height: 100%;
  }

  .launch-hero__media-panel img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    background: transparent;
  }

  .launch-hero__media-panel picture {
    display: contents;
  }

  @media (max-width: 720px) {
    .launch-hero__announcement {
      gap: 0.4rem;
      font-size: 0.63rem;
    }

    .launch-hero__badge {
      padding: 0.04rem 0.22rem;
    }

    .launch-hero__snippet-panel {
      padding: 0.82rem 0.9rem;
    }

    .launch-hero__media {
    }
  }
</style>
