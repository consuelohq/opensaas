---
import {
  launchAnnouncement,
  launchHero,
  launchTabs,
} from '../../data/launch-content';

type Props = {
  sectionId?: string;
};

const { sectionId } = Astro.props as Props;
---

<section class="launch-section" id={sectionId}>
  <div class="launch-content launch-content--wide launch-hero">
    <div class="launch-hero__announcement launch-mono">
      <span class="launch-hero__badge">{launchAnnouncement.badge}</span>
      <span>{launchAnnouncement.text}</span>
      <a class="launch-inline-link" href={launchAnnouncement.linkHref}>{launchAnnouncement.linkLabel}</a>
    </div>

    <div class="launch-hero__copy">
      <h1 class="launch-title">{launchHero.title}</h1>
      <p class="launch-copy">{launchHero.description}</p>
    </div>

    <div class="launch-hero__snippet launch-card" data-launch-hero>
      <div class="launch-hero__tabs launch-mono" role="tablist" aria-label="Consuelo surfaces">
        {launchTabs.map((tab, index) => (
          <button
            class:list={['launch-hero__tab', { 'is-active': index === 0 }]}
            type="button"
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            data-tab-button={tab.id}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <div class="launch-hero__snippet-panels">
        {launchTabs.map((tab, index) => (
          <div class:list={['launch-hero__snippet-panel', { 'is-active': index === 0 }]} data-tab-panel={tab.id}>
            <p class="launch-hero__snippet-value launch-mono">{tab.value}</p>

            {tab.kind === 'link' && tab.href ? (
              <a class="launch-hero__snippet-action launch-mono" href={tab.href}>
                <span>open</span>
                <svg viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M3 8H13" />
                  <path d="M8.5 3.5L13 8L8.5 12.5" />
                </svg>
              </a>
            ) : (
              <button class="launch-hero__snippet-action launch-mono" type="button" data-copy-button={tab.id}>
                <span data-copy-label={tab.id}>copy</span>
                <svg viewBox="0 0 16 16" aria-hidden="true" data-copy-icon={tab.id}>
                  <path d="M3.5 8.5L6.5 11.5L12.5 4.5" />
                </svg>
              </button>
            )}
          </div>
        ))}
      </div>
    </div>

    <div class="launch-hero__media launch-card" data-launch-media>
      {launchTabs.map((tab, index) => (
        <figure class:list={['launch-hero__media-panel', { 'is-active': index === 0 }]} data-media-panel={tab.id}>
          <img src={tab.imageSrc} alt={tab.imageAlt} loading={index === 0 ? 'eager' : 'lazy'} />
        </figure>
      ))}
    </div>
  </div>
</section>

<script define:vars={{ launchTabs }}>
  const root = document.querySelector('[data-launch-hero]');
  const mediaRoot = document.querySelector('[data-launch-media]');

  if (root instanceof HTMLElement && mediaRoot instanceof HTMLElement) {
    const buttons = Array.from(root.querySelectorAll('[data-tab-button]'));
    const panels = Array.from(root.querySelectorAll('[data-tab-panel]'));
    const mediaPanels = Array.from(mediaRoot.querySelectorAll('[data-media-panel]'));
    const copyButtons = Array.from(root.querySelectorAll('[data-copy-button]'));
    let activeIndex = 0;
    let rotationHandle;

    const sync = (nextIndex) => {
      activeIndex = nextIndex;
      buttons.forEach((button, index) => {
        const isActive = index === nextIndex;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      panels.forEach((panel, index) => panel.classList.toggle('is-active', index === nextIndex));
      mediaPanels.forEach((panel, index) => panel.classList.toggle('is-active', index === nextIndex));
    };

    const restartRotation = () => {
      window.clearInterval(rotationHandle);
      rotationHandle = window.setInterval(() => {
        sync((activeIndex + 1) % launchTabs.length);
      }, 6500);
    };

    buttons.forEach((button, index) => {
      button.addEventListener('click', () => {
        sync(index);
        restartRotation();
      });
    });

    copyButtons.forEach((button) => {
      button.addEventListener('click', async () => {
        const tabId = button.getAttribute('data-copy-button');
        const entry = launchTabs.find((tab) => tab.id === tabId);

        if (!entry) {
          return;
        }

        await navigator.clipboard.writeText(entry.value);

        const label = root.querySelector('[data-copy-label="' + tabId + '"]');
        const icon = root.querySelector('[data-copy-icon="' + tabId + '"]');

        if (label instanceof HTMLElement) {
          label.textContent = 'copied';
        }

        if (icon instanceof SVGElement) {
          icon.dataset.copied = 'true';
        }

        button.classList.add('is-copied');
        window.setTimeout(() => {
          if (label instanceof HTMLElement) {
            label.textContent = 'copy';
          }

          if (icon instanceof SVGElement) {
            icon.dataset.copied = 'false';
          }

          button.classList.remove('is-copied');
        }, 1400);
      });
    });

    sync(0);
    restartRotation();
  }
</script>

<style>
  .launch-hero {
    display: grid;
    gap: 1.25rem;
    padding-top: clamp(1.6rem, 1.15rem + 1.35vw, 2.8rem);
    padding-bottom: clamp(1.6rem, 1.15rem + 1.35vw, 2.8rem);
  }

  .launch-hero__announcement {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    color: var(--launch-muted);
    font-size: 0.76rem;
  }

  .launch-hero__badge {
    border: 1px solid var(--launch-line);
    padding: 0.12rem 0.35rem;
    color: var(--launch-fg);
    background: var(--launch-panel);
  }

  .launch-hero__copy {
    display: grid;
    gap: 1rem;
    max-width: 42rem;
  }

  .launch-hero__snippet {
    overflow: hidden;
  }

  .launch-hero__tabs {
    display: flex;
    gap: 0.15rem;
    overflow-x: auto;
    border-bottom: 1px solid var(--launch-line);
    padding: 0.35rem 0.35rem 0;
    scrollbar-width: none;
  }

  .launch-hero__tabs::-webkit-scrollbar {
    display: none;
  }

  .launch-hero__tab {
    border: 0;
    background: transparent;
    color: var(--launch-muted);
    padding: 0.75rem 0.8rem;
    cursor: pointer;
    white-space: nowrap;
    font-size: 0.76rem;
  }

  .launch-hero__tab.is-active {
    background: var(--launch-bg);
    color: var(--launch-fg);
    border-left: 1px solid var(--launch-line);
    border-right: 1px solid var(--launch-line);
    border-top: 1px solid var(--launch-line);
    margin-bottom: -1px;
  }

  .launch-hero__snippet-panels {
    background: var(--launch-panel);
  }

  .launch-hero__snippet-panel {
    display: none;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
  }

  .launch-hero__snippet-panel.is-active {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .launch-hero__snippet-value {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.6;
    overflow-wrap: anywhere;
  }

  .launch-hero__snippet-action {
    min-height: 2.25rem;
    padding: 0 0.75rem;
    border: 1px solid var(--launch-line);
    background: transparent;
    color: var(--launch-muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    transition: color 160ms ease, background 160ms ease, border-color 160ms ease;
  }

  .launch-hero__snippet-action:hover {
    color: var(--launch-fg);
    background: var(--launch-bg);
  }

  .launch-hero__snippet-action svg {
    width: 0.9rem;
    height: 0.9rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.3;
    stroke-linecap: square;
    stroke-linejoin: miter;
  }

  .launch-hero__snippet-action[data-copy-button],
  .launch-hero__snippet-action.is-copied {
    cursor: pointer;
  }

  .launch-hero__snippet-action [data-copy-icon] {
    opacity: 0;
    transform: scale(0.7);
    transition: opacity 160ms ease, transform 160ms ease;
  }

  .launch-hero__snippet-action [data-copy-icon][data-copied='true'] {
    opacity: 1;
    transform: scale(1);
    color: var(--launch-success);
  }

  .launch-hero__snippet-action.is-copied {
    color: var(--launch-success);
    border-color: color-mix(in srgb, var(--launch-success) 55%, var(--launch-line));
  }

  .launch-hero__media {
    position: relative;
    overflow: hidden;
    min-height: clamp(17rem, 32vw, 31rem);
    background: var(--launch-panel);
  }

  .launch-hero__media-panel {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    transform: scale(1.01);
    transition: opacity 260ms ease, transform 260ms ease;
    pointer-events: none;
  }

  .launch-hero__media-panel.is-active {
    opacity: 1;
    transform: scale(1);
  }

  .launch-hero__media-panel img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 720px) {
    .launch-hero {
      gap: 1rem;
    }

    .launch-hero__snippet-panel.is-active {
      grid-template-columns: minmax(0, 1fr);
    }

    .launch-hero__snippet-action {
      width: fit-content;
    }

    .launch-hero__media {
      min-height: 15rem;
    }
  }
</style>
