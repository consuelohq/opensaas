---
import {
  launchAnnouncement,
  launchHero,
  launchTabs,
} from '../../data/launch-content';

type Props = {
  sectionId?: string;
};

const { sectionId } = Astro.props as Props;
---

<section class="launch-section" id={sectionId}>
  <div class="launch-content launch-content--wide launch-hero">
    <div class="launch-hero__announcement launch-mono">
      <span class="launch-hero__badge">{launchAnnouncement.badge}</span>
      <span>{launchAnnouncement.text}</span>
      <a class="launch-inline-link" href={launchAnnouncement.linkHref}>{launchAnnouncement.linkLabel}</a>
    </div>

    <div class="launch-hero__copy">
      <h1 class="launch-title">{launchHero.title}</h1>
      <p class="launch-copy">{launchHero.description}</p>
    </div>

    <div class="launch-hero__snippet launch-card" data-launch-hero>
      <div class="launch-hero__tabs launch-mono" role="tablist" aria-label="Consuelo surfaces">
        {launchTabs.map((tab, index) => (
          <button
            class:list={['launch-hero__tab', { 'is-active': index === 0 }]}
            type="button"
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            data-tab-button={tab.id}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <div class="launch-hero__snippet-panels">
        {launchTabs.map((tab, index) => (
          <div class:list={['launch-hero__snippet-panel', { 'is-active': index === 0 }]} data-tab-panel={tab.id}>
            {tab.kind === 'link' && tab.href ? (
              <a class="launch-hero__snippet-value launch-mono is-link" href={tab.href}>{tab.value}</a>
            ) : (
              <code class="launch-hero__snippet-value launch-mono">{tab.value}</code>
            )}

            {tab.kind === 'link' && tab.href ? (
              <a class="launch-hero__snippet-action" href={tab.href} aria-label={'open ' + tab.label}>
                <svg viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M3 8H13" />
                  <path d="M8.5 3.5L13 8L8.5 12.5" />
                </svg>
              </a>
            ) : (
              <button class="launch-hero__snippet-action" type="button" data-copy-button={tab.id} aria-label={'copy ' + tab.label + ' command'}>
                <svg class="launch-hero__copy-icon" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M6 3.5H12.5V10" />
                  <path d="M3.5 6H10V12.5H3.5Z" />
                </svg>
                <svg class="launch-hero__check-icon" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M3.5 8.5L6.5 11.5L12.5 4.5" />
                </svg>
              </button>
            )}
          </div>
        ))}
      </div>
    </div>

    <div class="launch-hero__media launch-card" data-launch-media>
      {launchTabs.map((tab, index) => (
        <figure class:list={['launch-hero__media-panel', { 'is-active': index === 0 }]} data-media-panel={tab.id}>
          <img src={tab.imageSrc} alt={tab.imageAlt} loading={index === 0 ? 'eager' : 'lazy'} />
        </figure>
      ))}
    </div>
  </div>
</section>

<script define:vars={{ launchTabs }}>
  const root = document.querySelector('[data-launch-hero]');
  const mediaRoot = document.querySelector('[data-launch-media]');

  if (root instanceof HTMLElement && mediaRoot instanceof HTMLElement) {
    const buttons = Array.from(root.querySelectorAll('[data-tab-button]'));
    const panels = Array.from(root.querySelectorAll('[data-tab-panel]'));
    const mediaPanels = Array.from(mediaRoot.querySelectorAll('[data-media-panel]'));
    const copyButtons = Array.from(root.querySelectorAll('[data-copy-button]'));
    let activeIndex = 0;
    let rotationHandle;

    const sync = (nextIndex) => {
      activeIndex = nextIndex;
      buttons.forEach((button, index) => {
        const isActive = index === nextIndex;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      panels.forEach((panel, index) => panel.classList.toggle('is-active', index === nextIndex));
      mediaPanels.forEach((panel, index) => panel.classList.toggle('is-active', index === nextIndex));
    };

    const restartRotation = () => {
      window.clearInterval(rotationHandle);
      rotationHandle = window.setInterval(() => {
        sync((activeIndex + 1) % launchTabs.length);
      }, 6500);
    };

    buttons.forEach((button, index) => {
      button.addEventListener('click', () => {
        sync(index);
        restartRotation();
      });
    });

    copyButtons.forEach((button) => {
      button.addEventListener('click', async () => {
        const tabId = button.getAttribute('data-copy-button');
        const entry = launchTabs.find((tab) => tab.id === tabId);

        if (!entry) {
          return;
        }

        await navigator.clipboard.writeText(entry.value);
        button.classList.add('is-copied');
        window.setTimeout(() => {
          button.classList.remove('is-copied');
        }, 1400);
      });
    });

    sync(0);
    restartRotation();
  }
</script>

<style>
  .launch-hero {
    display: grid;
    gap: 1.25rem;
    padding-top: clamp(2rem, 1.5rem + 2vw, 3.5rem);
    padding-bottom: clamp(2rem, 1.5rem + 2vw, 3.5rem);
  }

  .launch-hero__announcement {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    color: var(--launch-muted);
    font-size: 0.78rem;
  }

  .launch-hero__badge {
    border: 1px solid color-mix(in srgb, var(--launch-line) 40%, transparent);
    padding: 0.08rem 0.28rem;
    color: var(--launch-fg);
    background: var(--launch-panel);
    transition: border-color 160ms ease;
  }

  .launch-hero__announcement:hover .launch-hero__badge {
    border-color: var(--launch-line);
  }

  .launch-hero__copy {
    display: grid;
    gap: 0.85rem;
    max-width: 37rem;
  }

  .launch-hero__snippet {
    overflow: hidden;
  }

  .launch-hero__tabs {
    display: flex;
    gap: 0.15rem;
    overflow-x: auto;
    border-bottom: 1px solid var(--launch-line);
    padding: 0.15rem 0.28rem 0;
    scrollbar-width: none;
  }

  .launch-hero__tabs::-webkit-scrollbar {
    display: none;
  }

  .launch-hero__tab {
    border: 0;
    background: transparent;
    color: var(--launch-muted);
    padding: 0.45rem 0.78rem;
    white-space: nowrap;
    font-size: 0.88rem;
  }

  .launch-hero__tab.is-active {
    background: transparent;
    color: var(--launch-fg);
    border-bottom: 2px solid var(--launch-fg);
    margin-bottom: -1px;
  }

  .launch-hero__snippet-panels {
    background: var(--launch-panel);
  }

  .launch-hero__snippet-panel {
    display: none;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.85rem;
  }

  .launch-hero__snippet-panel.is-active {
    display: grid;
  }

  .launch-hero__snippet-value {
    margin: 0;
    min-width: 0;
    display: block;
    color: var(--launch-fg);
    font-size: 0.72rem;
    line-height: 1.5;
    overflow-wrap: anywhere;
  }

  .launch-hero__snippet-value.is-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .launch-hero__snippet-action {
    width: 1.6rem;
    height: 1.6rem;
    border: 1px solid color-mix(in srgb, var(--launch-line) 40%, transparent);
    background: transparent;
    color: var(--launch-muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 160ms ease, background 160ms ease, border-color 160ms ease;
  }

  .launch-hero__snippet-action:hover {
    color: var(--launch-fg);
    background: var(--launch-bg);
    border-color: var(--launch-line);
  }

  .launch-hero__snippet-action svg {
    width: 0.88rem;
    height: 0.88rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.3;
    stroke-linecap: square;
    stroke-linejoin: miter;
  }

  .launch-hero__check-icon {
    display: none;
  }

  .launch-hero__snippet-action.is-copied {
    color: var(--launch-success);
    border-color: color-mix(in srgb, var(--launch-success) 60%, var(--launch-line));
  }

  .launch-hero__snippet-action.is-copied .launch-hero__copy-icon {
    display: none;
  }

  .launch-hero__snippet-action.is-copied .launch-hero__check-icon {
    display: block;
  }

  .launch-hero__media {
    position: relative;
    overflow: hidden;
    min-height: clamp(20rem, 48vw, 48rem);
    background: var(--launch-panel);
  }

  .launch-hero__media-panel {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 280ms ease, transform 280ms ease;
    pointer-events: none;
  }

  .launch-hero__media-panel.is-active {
    opacity: 1;
    transform: translateY(0);
  }

  .launch-hero__media-panel img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  @media (max-width: 720px) {
    .launch-hero__snippet-panel {
      grid-template-columns: minmax(0, 1fr) auto;
      padding: 0.82rem 0.9rem;
    }

    .launch-hero__media {
      min-height: 16.5rem;
    }
  }
</style>
