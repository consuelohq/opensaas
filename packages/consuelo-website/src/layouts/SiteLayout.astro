---
import "../styles/global.css";
import Navbar from "../components/Navbar";
import SeoHead from '../components/SeoHead.astro';
import { siteMetadata } from '../lib/site-seo';

type Props = {
  title?: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  schemaEntries?: Array<Record<string, unknown>>;
};

const {
  title = siteMetadata.defaultTitle,
  description = siteMetadata.defaultDescription,
  image = siteMetadata.defaultOgImage,
  canonicalUrl = Astro.url.href,
  schemaEntries = [],
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      {title}
      {description}
      canonicalUrl={canonicalUrl}
      image={image}
      schemaEntries={schemaEntries}
    />
    <meta
      name="keywords"
      content="AI sales training, sales agent onboarding, CRM automation, sales coaching, insurance sales, sales enablement"
    />
  </head>
  <body class="bg-(--color-bg) text-(--color-fg) antialiased">
    <Navbar client:load />
    <slot name="header" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
