---
import HomeFaq from '../components/home/HomeFaq.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import HomeHero from '../components/home/HomeHero.astro';
import HomeMercuryPromo from '../components/home/HomeMercuryPromo.astro';
import HomeOverview from '../components/home/HomeOverview.astro';
import HomePrivacy from '../components/home/HomePrivacy.astro';
import HomeStats from '../components/home/HomeStats.astro';
import { homeFaqItems } from '../data/home-content';
import { homePageSections } from '../data/site-navigation';
import { getFaqSchema, getSoftwareApplicationSchema } from '../lib/site-seo';
import MarketingLayout from '../layouts/MarketingLayout.astro';

const description = 'Sales infrastructure for insurance sales teams with a connected crm, dialer, real-time ai coaching, and workflow surfaces that integrate everywhere your team works.';

const schemaEntries = [
  getSoftwareApplicationSchema({
    offers: {
      '@type': 'AggregateOffer',
      lowPrice: '0',
      highPrice: '20',
      priceCurrency: 'USD',
      offerCount: '2',
    },
  }),
  getFaqSchema(homeFaqItems),
];
---

<MarketingLayout
  title="Consuelo | Sales Infrastructure for Insurance Sales Teams"
  description={description}
  canonicalPath="/"
  image="/og.png"
  schemaEntries={schemaEntries}
>
  <script is:inline>
    (() => {
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.dataset.heroMotionReady = 'true';
      }
    })();
  </script>
  <SiteHeader pageSections={homePageSections} />
  <HomeHero sectionId="intro" />
  <script>
    import { bootHomeHeroMotion, bootProofSvgMotion } from "../lib/motion";

    bootHomeHeroMotion();
    bootProofSvgMotion();
  </script>
  <HomeOverview sectionId="overview" />
  <HomeStats sectionId="proof" />
  <HomePrivacy sectionId="privacy" />
  <HomeFaq sectionId="faq" items={homeFaqItems} />
  <HomeMercuryPromo sectionId="mercury" />
  <SiteFooter sectionId="waitlist" />
</MarketingLayout>
