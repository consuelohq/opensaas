---
import SiteLayout from "../layouts/SiteLayout.astro";
import { Hero } from "../components/Hero";
import { ProblemSection } from "../components/ProblemSection";
import { SolutionSection } from "../components/SolutionSection";

const features = [
  {
    label: "SALES TOOLS",
    items: [
      { title: "Power Dialer", desc: "Multi-line dials, increased contact rate and volume", icon: "/icons/power-dialer.li" },
      { title: "Local Presence", desc: "Call from local numbers everywhere", icon: "/icons/local-presence.li" },
      { title: "Call Transfer", desc: "Warm and cold transfers without dropping", icon: "/icons/call-transfer.li" },
      { title: "Spam Shield", desc: "Protect your numbers and reputation", icon: "/icons/spam-shield.li" },
    ],
  },
  {
    label: "AI",
    items: [
      { title: "AI CRM", desc: "Talk to your CRM — tell it what to do", icon: "/icons/ai-crm.li" },
      { title: "On-Call Coaching", desc: "Real-time whispers that increase time on call", icon: "/icons/on-call-coaching.li" },
      { title: "AI Queue", desc: "Automatically create and manage your call queue", icon: "/icons/ai-queue.li" },
      { title: "Script Mode", desc: "Upload scripts for whisper training", icon: "/icons/script-mode.li" },
    ],
  },
  {
    label: "AUTOMATION",
    items: [
      { title: "Lead Disbursement", desc: "Distribute leads across your team instantly", icon: "/icons/lead-disbursement.li" },
      { title: "Post-Sale Sequences", desc: "Auto follow-up at one week, one month, three months", icon: "/icons/post-sale-sequences.li" },
      { title: "Re-engagement Queues", desc: "Auto-queue old leads that didn't answer", icon: "/icons/re-engagement-queues.li" },
      { title: "Pipeline Nourishment", desc: "Reduce chargebacks with automated nurture", icon: "/icons/pipeline-nourishment.li" },
    ],
  },
  {
    label: "INTEGRATIONS",
    items: [
      { title: "GoHighLevel", desc: "Embedded GHL in your workflow", icon: "/icons/gohighlevel.li" },
      { title: "Google Extension", desc: "Consuelo everywhere you work in Chrome", icon: "/icons/google-extension.li" },
      { title: "Ads to CRM", desc: "Connect your ads platform straight to your CRM", icon: "/icons/ads-to-crm.li" },
      { title: "Chat SDK", desc: "Extends to Discord, Slack, and Teams", icon: "/icons/chat-sdk.li" },
    ],
  },
];
---

<SiteLayout>
  <!-- hero -->
  <Hero client:load />

  <!-- problem + solution — emotional bridge between hero and features -->
  <ProblemSection client:visible />
  <SolutionSection client:visible />

  <!-- features grid — one section per category, alternating -->
  {features.map((group, i) => (
    <section class="py-20 sm:py-24">
      <div class="mx-auto max-w-[1000px] px-6">
        <p class="mb-3 text-xs font-medium tracking-[0.1em] text-(--color-muted)">{group.label}</p>
        <div class="grid gap-6 sm:grid-cols-2">
          {group.items.map((item) => (
            <div class="flex gap-4 rounded-xl border border-(--color-border) p-5 transition-colors hover:border-(--color-muted)">
              <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-(--color-border)">
                {/* @ts-expect-error lord-icon is a web component */}
                <lord-icon src={item.icon} trigger="hover" class="current-color" style="width:22px;height:22px" />
              </span>
              <div>
                <p class="text-[15px] font-medium">{item.title}</p>
                <p class="mt-1 text-sm text-(--color-muted)">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- open source callout — surface-1 -->
  <section class=" py-20 sm:py-24">
    <div class="mx-auto max-w-[600px] px-6 text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Open source, from day one.</h2>
      <p class="mt-4 text-(--color-muted)">
        Every package is open source. Self-host, extend, contribute — no vendor lock-in.
      </p>
      <a href="https://github.com/consuelohq/opensaas" class="mt-8 inline-flex items-center gap-2 rounded-full border border-(--color-border) px-6 py-3 text-sm font-medium transition-colors hover:border-(--color-muted)">
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        View on GitHub
      </a>
    </div>
  </section>

  <!-- final cta — surface-0 -->
  <section class=" py-20 sm:py-28">
    <div class="mx-auto max-w-[600px] px-6 text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Ready to shorten ramp time?</h2>
      <p class="mt-4 text-(--color-muted)">Get your team selling faster with AI-powered coaching and a dialer built for speed.</p>
      <div class="mt-8 flex justify-center gap-4">
        <a href="/demo" class="rounded-full bg-(--color-fg) px-7 py-3 text-sm font-medium text-(--color-bg) transition-opacity hover:opacity-80">
          Book a demo
        </a>
        <a href="/signup" class="rounded-full border border-(--color-border) px-7 py-3 text-sm font-medium text-(--color-muted) transition-colors hover:text-(--color-fg)">
          Start for free
        </a>
      </div>
    </div>
  </section>
</SiteLayout>
