---
import SiteFooter from '../components/site/SiteFooter.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import HomeHero from '../components/home/HomeHero.astro';
import { getSoftwareApplicationSchema } from '../lib/site-seo';
import MarketingLayout from '../layouts/MarketingLayout.astro';

const description = 'Give every agent workspace superpowers with Consuelo OS, the open workspace layer for agents, teams, and tools.';

const schemaEntries = [
  getSoftwareApplicationSchema({
    offers: {
      '@type': 'AggregateOffer',
      lowPrice: '0',
      highPrice: '20',
      priceCurrency: 'USD',
      offerCount: '2',
    },
  }),
];
---

<MarketingLayout
  title="Consuelo | Workspace superpowers for every agent"
  description={description}
  canonicalPath="/"
  image="/og.png"
  schemaEntries={schemaEntries}
>
  <SiteHeader pageSections={[]} />
  <HomeHero sectionId="intro" />
  <SiteFooter />
</MarketingLayout>
