---
import LaunchFaq from '../components/launch/LaunchFaq.astro';
import LaunchFooter from '../components/launch/LaunchFooter.astro';
import LaunchHeader from '../components/launch/LaunchHeader.astro';
import LaunchHero from '../components/launch/LaunchHero.astro';
import LaunchMercuryPromo from '../components/launch/LaunchMercuryPromo.astro';
import LaunchOverview from '../components/launch/LaunchOverview.astro';
import LaunchPrivacy from '../components/launch/LaunchPrivacy.astro';
import LaunchStats from '../components/launch/LaunchStats.astro';
import { launchFaqItems, launchPageSections } from '../data/launch-content';
import { getFaqSchema, getSoftwareApplicationSchema } from '../lib/site-seo';
import LaunchLayout from '../layouts/LaunchLayout.astro';

const description = 'Sales infrastructure for insurance sales teams with a connected crm, dialer, real-time ai coaching, and workflow surfaces that integrate everywhere your team works.';

const schemaEntries = [
  getSoftwareApplicationSchema({
    offers: {
      '@type': 'AggregateOffer',
      lowPrice: '0',
      highPrice: '20',
      priceCurrency: 'USD',
      offerCount: '2',
    },
  }),
  getFaqSchema(launchFaqItems),
];
---

<LaunchLayout
  title="Consuelo | Sales Infrastructure for Insurance Sales Teams"
  description={description}
  canonicalPath="/"
  image="/og.png"
  schemaEntries={schemaEntries}
>
  <script is:inline>
    (() => {
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.dataset.heroMotionReady = 'true';
      }
    })();
  </script>
  <LaunchHeader pageSections={launchPageSections} />
  <LaunchHero sectionId="intro" />
  <script>
    import { bootLaunchHeroMotion } from '../lib/motion';

    bootLaunchHeroMotion();
  </script>
  <LaunchOverview sectionId="overview" />
  <LaunchStats sectionId="proof" />
  <LaunchPrivacy sectionId="privacy" />
  <LaunchFaq sectionId="faq" items={launchFaqItems} />
  <LaunchMercuryPromo sectionId="mercury" />
  <LaunchFooter sectionId="waitlist" />
</LaunchLayout>
