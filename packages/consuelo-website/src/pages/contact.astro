---
import SiteFooter from '../components/site/SiteFooter.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { contactFaqItems } from '../data/contact-content';

const description = 'Contact the Consuelo team for support or inquiries.';
---

<MarketingLayout title="Contact Us" description={description}>
  <SiteHeader />

  <section class="launch-section">
    <div class="launch-content launch-content--wide contact-split">
      <!-- Left side: Text -->
      <div class="contact-split__text">
        <h1 class="contact-hero__title launch-mono">Your infrastructure is yours</h1>
        <p class="launch-copy">
          Consuelo operates securely inside your organization with no data or context stored and no licensing restrictions or ownership claims. Start a trial with your team, then deploy it across your organization by integrating it with your SSO and internal AI gateway.
        </p>
        <p class="launch-copy">
          Let us know how we can help.
        </p>
      </div>

      <!-- Right side: Form -->
      <div class="contact-split__form">
        <form class="launch-form">
          <div class="launch-form__field">
            <label class="launch-mono" for="fullName">Full name</label>
            <input type="text" id="fullName" name="fullName" placeholder="Jeff Bezos" />
          </div>
          <div class="launch-form__field">
            <label class="launch-mono" for="role">Role</label>
            <input type="text" id="role" name="role" placeholder="Executive Chairman" />
          </div>
          <div class="launch-form__field">
            <label class="launch-mono" for="company">Company</label>
            <input type="text" id="company" name="company" placeholder="Acme Inc" />
          </div>
          <div class="launch-form__field">
            <label class="launch-mono" for="email">Company email</label>
            <input type="email" id="email" name="email" placeholder="jeff@amazon.com" required />
          </div>
          <div class="launch-form__field">
            <label class="launch-mono" for="phone">Phone number</label>
            <input type="tel" id="phone" name="phone" placeholder="+1 234 567 8900" />
          </div>
          <div class="launch-form__field">
            <label class="launch-mono" for="message">What problem are you trying to solve?</label>
            <textarea id="message" name="message" rows="4" placeholder="We need help with..." required></textarea>
          </div>
          <button type="submit" class="launch-button launch-button--sm launch-mono">Send Message ↗</button>
        </form>
      </div>
    </div>
  </section>

  <section class="launch-section">
    <div class="launch-content launch-content--wide contact-block">
      <p class="contact-block__eyebrow launch-mono">FAQ</p>
      {contactFaqItems.map((item) => (
        <details class="contact-expandable">
          <summary class="contact-expandable__trigger launch-mono">{item.question}</summary>
          <p class="launch-copy contact-expandable__body">{item.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <SiteFooter />
</MarketingLayout>

<style>
  .contact-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-top: clamp(2.5rem, 2rem + 2vw, 5rem);
    padding-bottom: clamp(2.5rem, 2rem + 2vw, 5rem);
  }

  @media (min-width: 768px) {
    .contact-split {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .contact-split__text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-hero__title {
    margin: 0;
    font-size: clamp(1.6rem, 1rem + 2.2vw, 2.4rem);
    font-weight: 700;
    line-height: 1.2;
  }

  .contact-split__text .launch-copy {
    font-family: var(--launch-mono-font);
    line-height: 1.6;
    opacity: 0.8;
  }

  /* Form Styles */
  .launch-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .launch-form__field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .launch-form__field label {
    font-size: 0.85rem;
    color: var(--launch-fg);
    opacity: 0.8;
    text-transform: none; /* remove uppercase to match opencode screenshot */
  }

  .launch-form__field input,
  .launch-form__field textarea {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--launch-fg);
    padding: 0.8rem 1rem;
    font-family: var(--launch-mono-font);
    font-size: 0.9rem;
    border-radius: 4px;
    outline: none;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  
  @media (prefers-color-scheme: light) {
    .launch-form__field input,
    .launch-form__field textarea {
      background: rgba(0, 0, 0, 0.03);
      border: 1px solid rgba(0, 0, 0, 0.1);
    }
  }

  .launch-form__field input:focus,
  .launch-form__field textarea:focus {
    border-color: var(--launch-fg);
    background: rgba(255, 255, 255, 0.05);
  }
  
  @media (prefers-color-scheme: light) {
    .launch-form__field input:focus,
    .launch-form__field textarea:focus {
      background: rgba(0, 0, 0, 0.05);
    }
  }

  .launch-form__field input::placeholder,
  .launch-form__field textarea::placeholder {
    color: var(--launch-muted);
    opacity: 0.5;
  }

  .launch-form .launch-button {
    align-self: flex-start;
    margin-top: 0.5rem;
    cursor: pointer;
    background: var(--launch-fg);
    color: var(--launch-bg);
    border: none;
  }
  
  @media (prefers-color-scheme: dark) {
    .launch-form .launch-button {
      background: white;
      color: black;
    }
  }

  /* shared block */
  .contact-block {
    display: grid;
    gap: 1rem;
    padding-top: clamp(1.5rem, 1rem + 1.5vw, 2.5rem);
    padding-bottom: clamp(1.5rem, 1rem + 1.5vw, 2.5rem);
    border-top: 1px solid var(--launch-line);
  }

  .contact-block__eyebrow {
    margin: 0;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--launch-fg);
    font-weight: 700;
  }

  /* expandable items (from mercury) */
  .contact-expandable {
    border-top: 1px solid var(--launch-line);
    padding: 0.75rem 0;
  }

  .contact-expandable:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .contact-expandable__trigger {
    font-size: clamp(0.82rem, 0.78rem + 0.16vw, 0.92rem);
    cursor: pointer;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem;
  }

  .contact-expandable__trigger::-webkit-details-marker {
    display: none;
  }

  .contact-expandable__trigger::before {
    content: '(+)';
    flex-shrink: 0;
    color: var(--launch-muted);
    font-size: 0.78rem;
  }

  details[open] .contact-expandable__trigger::before {
    content: '(−)';
  }

  .contact-expandable__body {
    padding: 0.5rem 0 0 1.6rem;
  }
</style>
