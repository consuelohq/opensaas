---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'
// - UI
import FormHero from '../components/blocks/hero/ContactHero.astro'
import CTA from '../components/blocks/CTA/BasicDark.astro'
import ContactCards from '../components/blocks/contact/ContactCards.astro'
import SocialProof from '../components/blocks/socialproof/Basic.astro'

// Content
// - SEO
const SEO = {
	title: 'Consuelo | Contact Us',
	description:
		'Get in touch with the Consuelo team — support for our power dialer, AI CRM, and real-time coaching platform built for insurance sales teams.'
}
// - Page Header
const header = {
	title: 'Talk to the <strong>Consuelo</strong> Team.',
	text: "Whether you need help setting up your dialer, have questions about our CRM, or want to share feedback — we're here for you."
}
---

<Layout title={SEO.title} description={SEO.description}>
	<FormHero
		title={header.title}
		text={header.text}
		id="contact"
		classes="bg-neutral-50 dark:bg-neutral-950/80"
	/>
	<ContactCards classes="dark:bg-neutral-950/80" />
	<SocialProof classes="dark:bg-neutral-950/80" />
	<CTA />
</Layout>
