---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'
// - UI
import Hero from '../components/blocks/hero/PageHeader.astro'
import FAQ from '../components/blocks/FAQ/FaqSticky.astro'
import TextImage from '../components/blocks/basic/TextImage.astro'
import CTA from '../components/blocks/CTA/BasicDark.astro'

// Data
import faqData from '../data/json-files/faqData.json'
// - FAQ Categories
const faqPricing = faqData.filter((faq) => faq.category === 'pricing')
const faqFeatures = faqData.filter((faq) => faq.category === 'features')
const faqIntegrations = faqData.filter((faq) => faq.category === 'integrations')

// Content
import faqImage1 from '../assets/faq/faq-01.png'
// - SEO
const SEO = {
	title: 'Consuelo | FAQ — Pricing, Features, Integrations',
	description:
		'Get answers about Consuelo pricing, features, integrations, and how it works for insurance sales teams.'
}
// - Page Header
const header = {
	title: 'Frequently Asked <strong>Questions</strong>',
	text: 'Everything you need to know about Consuelo.'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero title={header.title} text={header.text} />
	<FAQ
		title="Pricing & Plans"
		text="Transparent pricing for insurance sales teams. No hidden fees, no contracts, no surprises."
		data={faqPricing}
	/>
	<TextImage
		title="Replace Your Entire Stack for $20/seat"
		text="Most insurance sales teams pay $250+/seat/mo across separate dialer, CRM, coaching, and analytics tools. Consuelo combines all four into one connected platform — so your data flows, your team collaborates, and your costs drop."
		image={faqImage1}
		mobileImage={faqImage1}
		imagePosition="left"
		offsetImage
		classes="bg-neutral-50 dark:bg-neutral-900 lg:!py-64"
	/>
	<FAQ
		title="Features & Capabilities"
		text="Power dialer, AI coaching, smart CRM, lead automation — everything your team needs to sell more."
		data={faqFeatures}
	/>
	<FAQ
		title="Integrations"
		text="Connect Consuelo to GoHighLevel, Zapier, Slack, and the tools your team already uses."
		data={faqIntegrations}
	/>
	<CTA />
</Layout>
