---
import LaunchFooter from '../../components/launch/LaunchFooter.astro';
import LaunchHeader from '../../components/launch/LaunchHeader.astro';
import LaunchLayout from '../../layouts/LaunchLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map((entry) => ({
    params: { id: decodeURI(entry.id) },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Format date
const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
};

// Calculate read time
const wordCount = entry.body ? entry.body.split(/\s+/).length : 500;
const readTime = Math.ceil(wordCount / 200);

// Use specific image or fallback to a generated SVG for this post
const ogImage = entry.data.image || `/og/${entry.id}.svg`;

// Schema.org Article JSON-LD
const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.title,
  "description": entry.data.description,
  "image": `https://www.consuelohq.com${ogImage}`,
  "author": {
    "@type": "Person",
    "name": entry.data.author || "Kokayi Cobb"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Consuelo",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.consuelohq.com/logo.svg"
    }
  },
  "datePublished": entry.data.pubDate.toISOString(),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://www.consuelohq.com/blog/${entry.id}`
  }
};
---

<LaunchLayout 
  title={entry.data.title} 
  description={entry.data.description}
  image={ogImage}
  type="article"
  publishDate={entry.data.pubDate}
  author={entry.data.author || "Kokayi Cobb"}
>
  <!-- Hidden on mobile to let content start immediately -->
  <div class="hidden md:block">
    <LaunchHeader />
  </div>
  
  <main class="launch-main">
    <article class="launch-section border-t-0 md:border-t" style="border-top-color: var(--launch-line);">
      <div class="launch-content launch-content--wide">
        
        <div class="blog-hero flex flex-col pt-16 md:pt-24 pb-12 w-full max-w-3xl mx-auto font-sans">
          
          <p class="text-launch-muted text-sm mb-10 font-medium tracking-wide text-center" style="color: var(--launch-muted);">Blog</p>
          
          <h1 class="blog-hero__title font-bold text-white tracking-tight mb-8 w-full text-center" style="font-size: clamp(2rem, 4vw, 3.5rem); line-height: 1.15; letter-spacing: -0.04em;">
            {entry.data.title}
          </h1>
          
          <div class="flex items-center justify-center gap-3 mb-16 w-full">
            <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-purple-500 to-pink-500 flex items-center justify-center text-white font-bold text-sm">
              {entry.data.author ? entry.data.author.charAt(0) : 'K'}
            </div>
            <div class="flex items-center gap-2">
              <span class="text-white text-sm font-medium">{entry.data.author || 'Kokayi Cobb'}</span>
              <span class="text-launch-muted text-sm" style="color: var(--launch-muted);">Product</span>
            </div>
          </div>

          <!-- Metadata & Share Actions Row -->
          <div class="w-full flex justify-between items-center py-6 border-t border-b" style="border-color: rgba(255,255,255,0.1);">
            <div class="flex items-center gap-6">
              <span class="text-launch-muted text-sm flex items-center gap-2 font-medium" style="color: var(--launch-muted);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                {readTime} min read
              </span>
              <button class="text-blue-400 text-sm flex items-center gap-2 font-medium hover:text-blue-300 transition-colors" onclick="navigator.clipboard.writeText(window.location.href); const t = this.querySelector('span'); const orig = t.innerText; t.innerText = 'Copied!'; setTimeout(() => t.innerText = orig, 2000);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                <span>Copy URL</span>
              </button>
            </div>
            <div class="text-launch-muted text-sm font-medium" style="color: var(--launch-muted);">
              {formatDate(entry.data.pubDate)}
            </div>
          </div>
        </div>

        <div class="mx-auto" style="max-width: 65ch;">
          <div class="prose prose-invert prose-lg font-sans prose-p:text-[#fafafa] prose-p:leading-relaxed prose-headings:text-white prose-headings:tracking-tight prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline prose-strong:text-white prose-li:text-[#fafafa] prose-img:rounded-xl">
            <Content />
          </div>
        </div>
        
      </div>
    </article>
  </main>

  <LaunchFooter />
  
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</LaunchLayout>

<style>
  .hidden { display: none; }
  @media (min-width: 768px) {
    .md\:block { display: block; }
    .md\:border-t { border-top-width: 1px; }
    .md\:pt-24 { padding-top: 6rem; }
  }
</style>
