---
import SiteFooter from '../components/site/SiteFooter.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import MarketingLayout from '../layouts/MarketingLayout.astro';
import feedData from '../data/json-files/changelogData.json';

const description = "See what's new in Consuelo — latest updates, features, and improvements.";

const parseVersion = (title: string) => {
  const match = title.match(/^(v[\d.]+)/);
  return match ? match[1] : title;
};

const formatDate = (date: string) => {
  const d = new Date(date);
  if (isNaN(d.getTime())) {
    return date;
  }
  return d.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric'
  });
};
---

<MarketingLayout title="Changelog" description={description} image="/changelog-og.png">
  <SiteHeader />
  
  <main class="launch-main">
    <section class="launch-section">
      <div class="launch-content launch-content--wide">
        
        <div class="cl-header">
          <h1 class="cl-title">Changelog</h1>
          <p class="cl-subtitle">New updates and improvements to Consuelo</p>
        </div>

        <div class="cl-entries">
          {feedData.map((item) => (
            <article class="cl-entry">
              <div class="cl-entry__meta">
                <span class="cl-entry__version">{parseVersion(item.title)}</span>
                <span class="cl-entry__date">{formatDate(item.date)}</span>
              </div>
              <div class="cl-entry__body">
                <div class="cl-entry__content" set:html={item.text} />
              </div>
            </article>
          ))}
        </div>
        
      </div>
    </section>
  </main>

  <SiteFooter />
</MarketingLayout>

<style>
  .cl-header {
    padding-top: clamp(3rem, 2rem + 3vw, 6rem);
    padding-bottom: clamp(2rem, 1.5rem + 2vw, 4rem);
    border-bottom: 1px solid var(--launch-line);
  }

  .cl-title {
    margin: 0;
    font-size: clamp(2rem, 1.5rem + 2.5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.1;
  }

  .cl-subtitle {
    margin: 0.5rem 0 0;
    color: var(--launch-muted);
    font-size: 1rem;
  }

  .cl-entries {
    display: flex;
    flex-direction: column;
  }

  .cl-entry {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 3rem;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--launch-line);
  }

  .cl-entry__meta {
    position: sticky;
    top: 5rem;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .cl-entry__version {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    color: var(--launch-fg);
  }

  .cl-entry__date {
    font-family: var(--launch-mono-font);
    font-size: 0.78rem;
    color: var(--launch-muted);
  }

  .cl-entry__body {
    min-width: 0;
  }

  .cl-entry__content {
    font-family: var(--launch-mono-font);
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--launch-muted);
  }

  .cl-entry__content :global(h4) {
    margin: 1.25rem 0 0.5rem;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--launch-fg);
    letter-spacing: -0.01em;
  }

  .cl-entry__content :global(h4:first-child) {
    margin-top: 0;
  }

  .cl-entry__content :global(p) {
    margin: 0 0 1rem;
  }

  .cl-entry__content :global(ul) {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .cl-entry__content :global(li) {
    padding-left: 0.5rem;
  }

  .cl-entry__content :global(li)::before {
    content: '- ';
    color: var(--launch-muted);
  }

  @media (max-width: 640px) {
    .cl-entry {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .cl-entry__meta {
      position: static;
      flex-direction: row;
      align-items: baseline;
      gap: 0.75rem;
    }
  }
</style>
