---
import LaunchFooter from '../components/launch/LaunchFooter.astro';
import LaunchHeader from '../components/launch/LaunchHeader.astro';
import { mercuryFaqItems, siteLinks } from '../data/launch-content';
import LaunchLayout from '../layouts/LaunchLayout.astro';

const description = 'Mercury is the hosted Consuelo plan. Twilio calling, AI models, and hosting — tested and configured. Start with $20 pay as you go.';

const icons = [
  { src: '/icons/twilio.svg', alt: 'Twilio' },
  { src: '/icons/anthropic.svg', alt: 'Anthropic' },
  { src: '/icons/openai.svg', alt: 'OpenAI' },
  { src: '/icons/groq.svg', alt: 'Groq' },
  { src: '/icons/railway.svg', alt: 'Railway' },
];

const problems = [
  'Too many moving parts',
  'Spam and compliance drag',
  'Insurance chargebacks',
  'Wanting more from AI'
];

const steps = [
  { n: '1', text: 'sign up and add $20 balance — follow the', link: 'setup instructions', href: siteLinks.docs },
  { n: '2', text: 'Use Mercury with transparent pricing — ', link: 'pay per request', href: siteLinks.docs, after: ' with zero markups' },
  { n: '3', text: 'auto-top up — when your balance reaches $5 we\'ll automatically add $20' },
];
---

<LaunchLayout title="Mercury" description={description} canonicalPath="/mercury">
  <LaunchHeader />

  <!-- hero -->
  <section class="launch-section" data-motion="section-reveal">
    <div class="launch-content launch-content--wide mercury-hero">
      <h1 class="mercury-hero__logo launch-mono" data-motion="hero-line">Mercury</h1>
      <h2 class="mercury-hero__subtitle" data-motion="hero-copy">Hosted calling and AI, ready to go.</h2>
      <p class="launch-copy" data-motion="hero-copy">Mercury is the hosted plan for teams that want to get live fast. It gives you Predictive dialer, AI models from OpenAI and Groq, and hosting on Railway without making you manage provider setup or infrastructure on day one.</p>
      <div class="mercury-hero__icons">
        {icons.map((icon) => (
          <img src={icon.src} alt={icon.alt} width="20" height="20" class="mercury-hero__icon" data-motion="commit-twinkle" />
        ))}
      </div>
      <a class="launch-button launch-button--sm launch-mono" href={siteLinks.app} data-motion="silver-glint">Get started with Mercury ↗</a>
      <p class="launch-copy mercury-hero__pricing" data-motion="hero-copy">$20 pay as you go balance (+$1.23 card processing fee)</p>
      <p class="launch-copy mercury-hero__note" data-motion="hero-copy">Use with any plan. Set monthly spend limits. Cancel any time.</p>
    </div>
  </section>

  <!-- problem -->
  <section class="launch-section" data-motion="section-reveal">
    <div class="launch-content launch-content--wide mercury-block">
      <p class="mercury-block__eyebrow launch-mono" data-motion="split-line">What problem is Mercury solving?</p>
      <p class="launch-copy" data-motion="split-line">Teams waste weeks configuring business accounts and fighting telecom spam flags instead of using a persistent tech layer that follows them across devices and contexts.</p>
      {problems.map((item) => (
        <details class="mercury-expandable" data-motion="faq">
          <summary class="mercury-expandable__trigger launch-mono" data-motion="faq-trigger silver-glint">{item}</summary>
        </details>
      ))}
    </div>
  </section>

  <!-- how it works -->
  <section class="launch-section" data-motion="section-reveal">
    <div class="launch-content launch-content--wide mercury-block">
      <p class="mercury-block__eyebrow launch-mono" data-motion="split-line">How Mercury works</p>
      <p class="launch-copy" data-motion="split-line">While we suggest you use Mercury with Consuelo, you can use Mercury with any sales tool.</p>
      {steps.map((step) => (
        <p class="mercury-step launch-copy" data-motion="feature-row">
          <span class="mercury-step__n launch-mono" data-motion="commit-twinkle">[{step.n}]</span>
          {step.text}{' '}
          {step.link && step.href && (
            <a class="launch-inline-link" href={step.href}>{step.link}</a>
          )}
          {step.after && (
            <span class="mercury-step__after">{' '}{step.after}</span>
          )}
        </p>
      ))}   </div>
  </section>

  <!-- privacy -->
  <section class="launch-section" data-motion="section-reveal">
    <div class="launch-content launch-content--wide mercury-block">
      <p class="mercury-block__eyebrow launch-mono" data-motion="split-line">Your privacy is important to us</p>
      <details class="mercury-expandable" data-motion="faq">
        <summary class="mercury-expandable__trigger launch-mono" style="color: var(--launch-muted)">All Mercury providers are hosted in the US. Providers follow a zero-retention policy and do not use your data for model training, with the <a class="launch-inline-link" href={siteLinks.docs}>following exceptions</a>.</summary>
      </details>
    </div>
  </section>

  <!-- faq -->
  <section class="launch-section" data-motion="section-reveal">
    <div class="launch-content launch-content--wide mercury-block">
      <p class="mercury-block__eyebrow launch-mono" data-motion="split-line">FAQ</p>
      {mercuryFaqItems.map((item) => (
        <details class="mercury-expandable" data-motion="faq">
          <summary class="mercury-expandable__trigger launch-mono" data-motion="faq-trigger silver-glint">{item.question}</summary>
          <p class="launch-copy mercury-expandable__body" data-motion="faq-body">{item.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <LaunchFooter />
</LaunchLayout>

<style>
  .mercury-hero {
    display: grid;
    gap: 0.75rem;
    padding-top: clamp(2.5rem, 2rem + 2vw, 5rem);
    padding-bottom: clamp(2.5rem, 2rem + 2vw, 5rem);
  }

  .mercury-hero__logo {
    margin: 0;
    font-size: clamp(1.6rem, 1rem + 2.2vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.06em;
    line-height: 1;
  }

  .mercury-hero__subtitle {
    margin: 0;
    font-family: var(--launch-mono-font);
    font-size: clamp(0.88rem, 0.82rem + 0.2vw, 0.95rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .mercury-hero__icons {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    padding: 0.5rem 0;
  }

  .mercury-hero__icon {
    width: 1.15rem;
    height: 1.15rem;
    opacity: 0.7;
  }

  @media (prefers-color-scheme: dark) {
    .mercury-hero__icon {
      filter: invert(1);
    }
  }

  .mercury-hero .launch-button {
    justify-self: start;
  }

  .mercury-hero__pricing {
    padding-top: 0.5rem;
  }

  .mercury-hero__note {
    font-size: clamp(0.76rem, 0.72rem + 0.14vw, 0.84rem);
  }

  /* shared block */
  .mercury-block {
    display: grid;
    gap: 0.75rem;
    padding-top: clamp(2rem, 1.5rem + 1.5vw, 3.5rem);
    padding-bottom: clamp(2rem, 1.5rem + 1.5vw, 3.5rem);
  }

  .mercury-block__eyebrow {
    margin: 0;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--launch-fg);
    font-weight: 700;
  }

  /* expandable items */
  .mercury-expandable {
    border-top: 1px solid var(--launch-line);
    padding: 0.75rem 0;
  }

  .mercury-expandable__trigger {
    font-size: clamp(0.82rem, 0.78rem + 0.16vw, 0.92rem);
    cursor: pointer;
    list-style: none;
    display: flex;
    flex-wrap: nowrap;
    align-items: flex-start;
    gap: 0.6rem;
  }

  .mercury-expandable__trigger::-webkit-details-marker {
    display: none;
  }

  .mercury-expandable__trigger::before {
    content: '(+)';
    flex-shrink: 0;
    color: var(--launch-muted);
    font-size: 0.78rem;
  }

  details[open] .mercury-expandable__trigger::before {
    content: '(−)';
  }

  .mercury-expandable__body {
    padding: 0.5rem 0 0 1.6rem;
  }

  /* steps */
  .mercury-step {
    border-top: 1px solid var(--launch-line);
    padding-top: 0.75rem;
    color: var(--launch-fg);
  }

  .mercury-step__n {
    color: var(--launch-muted);
    margin-right: 0.5rem;
  }

  @media (max-width: 720px) {
    .mercury-step__after {
      display: none;
    }
  }

  .mercury-step {
    border-top: 1px solid var(--launch-line);
    padding-top: 0.75rem;
    color: var(--launch-fg);
  }

  .mercury-step__n {
    color: var(--launch-muted);
    margin-right: 0.35rem;
  }

  @media (max-width: 720px) {
    .mercury-step__after {
      display: none;
    }
  }
</style>
