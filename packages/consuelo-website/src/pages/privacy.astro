---
import LaunchFooter from '../components/launch/LaunchFooter.astro';
import LaunchHeader from '../components/launch/LaunchHeader.astro';
import LaunchLayout from '../layouts/LaunchLayout.astro';
import { siteLinks } from '../data/launch-content';

const description = 'Privacy policy for Consuelo — how we collect, use, and protect your data.';
---

<LaunchLayout title="Privacy Policy" description={description}>
  <LaunchHeader />

  <section class="launch-section">
    <div class="launch-content launch-content--wide legal-hero">
      <h1 class="legal-hero__title launch-mono">privacy policy</h1>
      <p class="launch-copy">last updated: march 2026. your privacy matters to us.</p>
    </div>
  </section>

  <section class="launch-section">
    <div class="launch-content launch-content--wide legal-block">
      <p class="legal-block__eyebrow launch-mono">introduction</p>
      <p class="launch-copy">consuelo ("we", "us", "our") is committed to protecting your privacy. this policy explains what data we collect, how we use it, and your rights regarding that data.</p>

      <p class="legal-block__eyebrow launch-mono">who we are</p>
      <p class="launch-copy">consuelo operates the website at <strong>consuelohq.com</strong> and provides an open-source sales infrastructure platform including power dialer, ai crm, real-time coaching, and analytics for insurance sales teams. our registered office is located at [registered address].</p>
      <p class="launch-copy">for the purposes of data protection law, we are the data controller of your personal data. our data protection officer can be contacted at <strong>support@consuelohq.com</strong>.</p>

      <p class="legal-block__eyebrow launch-mono">scope</p>
      <p class="launch-copy">this privacy policy applies to visitors of consuelohq.com and users of our services. it does not apply to third-party websites that may be linked from our site. we encourage you to read the privacy policies of any third-party services you use.</p>
    </div>
  </section>

  <section class="launch-section">
    <div class="launch-content launch-content--wide legal-block">
      <p class="legal-block__eyebrow launch-mono">data we collect</p>
      <p class="launch-copy">we collect data automatically through our website using analytics tools. this section explains what we track and why.</p>

      <p class="legal-block__eyebrow launch-mono">analytics provider</p>
      <p class="launch-copy">we use <strong>posthog</strong> (posthog.com) as our analytics platform. posthog is a privacy-focused analytics provider that processes data on our behalf. you can learn more about posthog's data practices at <a class="launch-inline-link" href="https://posthog.com/privacy">posthog.com/privacy</a>.</p>

      <p class="legal-block__eyebrow launch-mono">what we track</p>
      <p class="launch-copy">when you visit our website, we automatically collect:</p>
      <ul class="launch-copy">
        <li><strong>page views:</strong> urls you visit, including the full path and query parameters</li>
        <li><strong>page leaves:</strong> when you navigate away from a page</li>
        <li><strong>clicks:</strong> elements you click on (autocaptured)</li>
        <li><strong>form submissions:</strong> forms you submit (autocaptured)</li>
        <li><strong>scroll depth:</strong> how far you scroll down a page (25%, 50%, 75%, 100%)</li>
        <li><strong>time on page:</strong> how long you spend on each page</li>
        <li><strong>session recordings:</strong> recordings of your interactions on our website</li>
        <li><strong>heatmaps:</strong> aggregated visual representations of user behavior</li>
        <li><strong>outbound link clicks:</strong> links you click that navigate away from our site</li>
      </ul>

      <p class="legal-block__eyebrow launch-mono">session recordings</p>
      <p class="launch-copy">we record user sessions to understand how people interact with our website and improve the user experience. session recordings capture:</p>
      <ul class="launch-copy">
        <li>mouse movements and clicks</li>
        <li>scrolling behavior</li>
        <li>page navigation</li>
        <li><strong>console logs</strong> (for debugging purposes)</li>
      </ul>
      <p class="launch-copy">session recordings are processed by posthog and are used solely to improve our product and website experience.</p>

      <p class="legal-block__eyebrow launch-mono">cross-domain tracking</p>
      <p class="launch-copy">we enable cross-subdomain tracking, which means your session data persists across <code>*.consuelohq.com</code> subdomains. this allows us to maintain a consistent understanding of your journey across our platform.</p>

      <p class="legal-block__eyebrow launch-mono">local storage & cookies</p>
      <p class="launch-copy">we use <strong>localstorage</strong> and <strong>cookies</strong> to persist your preferences and session data. this includes:</p>
      <ul class="launch-copy">
        <li>cookies for tracking consent status</li>
        <li>localstorage for session continuity</li>
        <li>cookies for cross-page analytics</li>
      </ul>
    </div>
  </section>

  <section class="launch-section">
    <div class="launch-content launch-content--wide legal-block">
      <p class="legal-block__eyebrow launch-mono">how we use your data</p>
      <p class="launch-copy">your data helps us improve our product and provide a better experience for all users.</p>

      <p class="legal-block__eyebrow launch-mono">purpose of processing</p>
      <p class="launch-copy">we use the data collected to:</p>
      <ul class="launch-copy">
        <li>understand how visitors interact with our website</li>
        <li>identify areas for improvement in our product and user experience</li>
        <li>analyze traffic patterns and user behavior</li>
        <li>debug technical issues when errors occur</li>
        <li>measure the effectiveness of our content and features</li>
        <li>make data-driven decisions about product development</li>
      </ul>

      <p class="legal-block__eyebrow launch-mono">legal basis for processing</p>
      <p class="launch-copy">under gdpr, we rely on <strong>consent</strong> as our legal basis for processing your personal data through our analytics tools. you can withdraw your consent at any time by declining cookies or contacting us.</p>
      <p class="launch-copy">under ccpa, we collect personal information for the business purposes described above. you have the right to know what information we collect, request deletion, and opt out of the sale of personal information (we do not sell personal information).</p>

      <p class="legal-block__eyebrow launch-mono">data retention</p>
      <p class="launch-copy">we retain analytics data for <strong>12 months</strong>. session recordings are retained for <strong>90 days</strong>. after these periods, data is automatically deleted from our systems.</p>
    </div>
  </section>

  <section class="launch-section">
    <div class="launch-content launch-content--wide legal-block">
      <p class="legal-block__eyebrow launch-mono">your rights</p>
      <p class="launch-copy">you have control over your data. this section explains your rights and how to exercise them.</p>

      <p class="legal-block__eyebrow launch-mono">opting out</p>
      <p class="launch-copy"><strong>you can opt out of tracking at any time.</strong> when you first visit our website, you will see a cookie banner. clicking <strong>"decline"</strong> will prevent us from loading analytics and tracking your behavior. if you previously accepted cookies, you can clear your browser's cookies and localstorage to reset your consent.</p>

      <p class="legal-block__eyebrow launch-mono">gdpr rights (eu/eea users)</p>
      <p class="launch-copy">if you are in the european union or european economic area, you have the right to:</p>
      <ul class="launch-copy">
        <li><strong>access:</strong> request a copy of your personal data</li>
        <li><strong>rectification:</strong> correct inaccurate personal data</li>
        <li><strong>erasure:</strong> request deletion of your personal data</li>
        <li><strong>restrict processing:</strong> limit how we use your data</li>
        <li><strong>data portability:</strong> receive your data in a portable format</li>
        <li><strong>object:</strong> object to processing of your personal data</li>
        <li><strong>withdraw consent:</strong> withdraw consent at any time</li>
      </ul>
      <p class="launch-copy">to exercise these rights, contact us at <strong>support@consuelohq.com</strong>. we will respond within 30 days of receiving your request.</p>

      <p class="legal-block__eyebrow launch-mono">ccpa rights (california users)</p>
      <p class="launch-copy">if you are a california resident, you have the right to:</p>
      <ul class="launch-copy">
        <li><strong>know:</strong> request disclosure of what personal information we collect</li>
        <li><strong>delete:</strong> request deletion of your personal information</li>
        <li><strong>opt-out:</strong> opt out of the sale of personal information (we do not sell)</li>
        <li><strong>non-discrimination:</strong> not be discriminated against for exercising your rights</li>
      </ul>
      <p class="launch-copy">we are required to disclose, at or before collection, the categories of personal information we collect and how we use it. we do not sell or share personal information for cross-context behavioral advertising.</p>

      <p class="legal-block__eyebrow launch-mono">do not track</p>
      <p class="launch-copy">we currently do not respond to do not track signals in your browser settings. if you wish to opt out of tracking, please use the cookie banner decline option or contact us.</p>
    </div>
  </section>

  <section class="launch-section">
    <div class="launch-content launch-content--wide legal-block">
      <p class="legal-block__eyebrow launch-mono">data sharing</p>
      <p class="launch-copy">your data may be shared with trusted third parties under specific circumstances.</p>

      <p class="legal-block__eyebrow launch-mono">third-party processors</p>
      <p class="launch-copy">we share your data with:</p>
      <ul class="launch-copy">
        <li><strong>posthog</strong> — our analytics provider, processes data on our behalf under a data processing agreement. posthog does not sell your data or use it for their own purposes.</li>
      </ul>

      <p class="legal-block__eyebrow launch-mono">legal requirements</p>
      <p class="launch-copy">we may disclose your data if required by law, regulation, or legal process. this includes responding to valid requests from public authorities, including for national security or law enforcement purposes.</p>

      <p class="legal-block__eyebrow launch-mono">business transfers</p>
      <p class="launch-copy">in the event of a merger, acquisition, or sale of assets, your data may be transferred as part of that transaction. we will notify you of any such change in ownership.</p>

      <p class="legal-block__eyebrow launch-mono">we do not sell your data</p>
      <p class="launch-copy">we do not sell, rent, or trade your personal information to third parties for their marketing purposes. your data is used solely to improve our product and user experience.</p>
    </div>
  </section>

  <section class="launch-section">
    <div class="launch-content launch-content--wide legal-block">
      <p class="legal-block__eyebrow launch-mono">security & international transfers</p>
      <p class="launch-copy">we take reasonable steps to protect your data, but no system is 100% secure.</p>

      <p class="legal-block__eyebrow launch-mono">data security</p>
      <p class="launch-copy">we implement appropriate technical and organizational measures to protect your personal data against unauthorized access, alteration, disclosure, or destruction. this includes:</p>
      <ul class="launch-copy">
        <li>encryption of data in transit (https)</li>
        <li>access controls and authentication</li>
        <li>regular security reviews</li>
      </ul>
      <p class="launch-copy">however, no method of transmission over the internet is 100% secure. we cannot guarantee absolute security of your data.</p>

      <p class="legal-block__eyebrow launch-mono">international data transfers</p>
      <p class="launch-copy">posthog processes data in the united states. if you are in the eu/eea, we rely on <strong>standard contractual clauses</strong> (sccs) as approved by the european commission to ensure adequate protection for cross-border transfers. posthog has signed these clauses as part of their data processing agreement.</p>
    </div>
  </section>

  <section class="launch-section">
    <div class="launch-content launch-content--wide legal-block">
      <p class="legal-block__eyebrow launch-mono">contact & changes</p>
      <p class="launch-copy">questions about this policy? we're here to help.</p>

      <p class="legal-block__eyebrow launch-mono">contact us</p>
      <p class="launch-copy">for questions about this privacy policy, to exercise your rights, or to report a privacy concern, please contact us:</p>
      <p class="launch-copy"><strong>email:</strong> support@consuelohq.com</p>

      <p class="legal-block__eyebrow launch-mono">changes to this policy</p>
      <p class="launch-copy">we may update this privacy policy from time to time. when we make material changes, we will notify you by posting the updated policy on this page and updating the "last updated" date. continued use of our services after changes constitutes acceptance of the updated policy.</p>
      <p class="launch-copy">we encourage you to review this policy periodically to stay informed about how we protect your data.</p>

      <p class="legal-block__eyebrow launch-mono">effective date</p>
      <p class="launch-copy">this privacy policy is effective as of <strong>march 2026</strong>.</p>
    </div>
  </section>

  <LaunchFooter />
</LaunchLayout>

<style>
  .legal-hero {
    display: grid;
    gap: 0.75rem;
    padding-top: clamp(2.5rem, 2rem + 2vw, 5rem);
    padding-bottom: clamp(1rem, 1rem + 1vw, 2rem);
  }

  .legal-hero__title {
    margin: 0;
    font-size: clamp(1.6rem, 1rem + 2.2vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.06em;
    line-height: 1;
  }

  /* shared block */
  .legal-block {
    display: grid;
    gap: 1rem;
    padding-top: clamp(1.5rem, 1rem + 1.5vw, 2.5rem);
    padding-bottom: clamp(1.5rem, 1rem + 1.5vw, 2.5rem);
    border-top: 1px solid var(--launch-line);
  }

  .legal-block__eyebrow {
    margin: 0;
    margin-top: 1rem;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--launch-fg);
    font-weight: 700;
  }
  
  .legal-block__eyebrow:first-child {
    margin-top: 0;
  }

  .legal-block ul {
    margin: 0;
    padding-left: 1.25rem;
    display: grid;
    gap: 0.5rem;
  }
  
  .legal-block li {
    font-size: clamp(0.82rem, 0.78rem + 0.16vw, 0.92rem);
    line-height: 1.5;
    color: var(--launch-fg);
  }
</style>
