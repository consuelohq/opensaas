---
const title = 'Sign in to Consuelo OS';
const description = 'Authorize Consuelo OS on this device.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="site-auth-body">
    <main class="device-auth site-auth-shell" data-device-auth>
      <section class="device-auth__copy-pane site-auth-copy-pane" aria-labelledby="device-auth-title">
        <a class="device-auth__brand" href="/" aria-label="Consuelo OS home">Consuelo OS</a>

        <div class="device-auth__form site-auth-form">
          <h1 id="device-auth-title">Sign in to Consuelo OS</h1>
          <p class="device-auth__instruction">Enter the code shown in your terminal.</p>

          <div class="device-auth__code-box site-auth-code-box" aria-live="polite">
            <strong class="device-auth__code" data-device-code>Waiting for code</strong>
          </div>

          <p class="device-auth__guardrail">
            Only continue if you just initiated a sign-in from your device.
          </p>

          <a
            class="device-auth__button site-auth-primary-action"
            data-device-continue
            data-os-device-approve-link
            href="https://app.consuelohq.com/auth/google?action=os-device-approval"
          >
            Continue with Google
          </a>
        </div>
      </section>

      <aside class="device-auth__visual site-auth-visual" aria-hidden="true">
        <div class="device-auth__mark site-auth-visual-mark">OS</div>
      </aside>
    </main>
  </body>
</html>

<script is:inline>
  const deviceCodeNode = document.querySelector('[data-device-code]');
  const approveLink = document.querySelector('[data-os-device-approve-link]');
  const rawUserCode = new URLSearchParams(window.location.search).get('user_code') ?? '';
  const normalizedUserCode = rawUserCode.replace(/[^a-z0-9]/gi, '').toUpperCase();
  const formattedUserCode = normalizedUserCode.replace(/(.{4})(?=.)/g, '$1-');

  if (deviceCodeNode && formattedUserCode) {
    deviceCodeNode.textContent = formattedUserCode;
  }

  if (approveLink && normalizedUserCode) {
    approveLink.href = `https://app.consuelohq.com/auth/google?action=os-device-approval&osDeviceUserCode=${encodeURIComponent(normalizedUserCode)}`;
  }
</script>

<style is:global>
  @import '../../styles/tokens.css';
  @import '../../styles/primitives.css';

  * {
    box-sizing: border-box;
  }

  .device-auth {
    grid-template-columns: minmax(0, var(--site-auth-copy-column)) minmax(0, var(--site-auth-visual-column));
  }

  .device-auth__copy-pane {
    padding: var(--site-space-12) clamp(var(--site-space-9), 6vw, var(--site-space-14)) var(--site-space-13);
  }

  .device-auth__brand {
    width: fit-content;
    color: var(--site-color-text-primary);
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1;
    text-decoration: none;
  }

  .device-auth__form {
    width: min(100%, var(--site-auth-form-width));
    align-self: center;
    gap: var(--site-space-8);
  }

  .device-auth__form h1 {
    margin: var(--site-space-0) var(--site-space-0) var(--site-space-10);
    color: var(--site-color-text-primary);
    font-size: 2.35rem;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.08;
  }

  .device-auth__instruction,
  .device-auth__guardrail {
    margin: var(--site-space-0);
    max-width: var(--site-auth-text-width);
    color: var(--site-color-text-secondary);
    font-size: 1rem;
    line-height: 1.55;
  }

  .device-auth__code-box {
    min-height: var(--site-auth-code-height);
  }

  .device-auth__code {
    color: var(--site-color-text-primary);
    font-family: var(--site-font-mono);
    font-size: 1.2rem;
    font-weight: 650;
    letter-spacing: 0;
    line-height: 1;
  }

  .device-auth__button {
    min-height: var(--site-auth-button-height);
    margin-top: var(--site-space-1);
    padding: var(--site-space-0) var(--site-space-6);
    border-radius: var(--site-radius-action);
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: 0;
    transition: opacity var(--site-motion-fast);
  }

  .device-auth__button:hover {
    opacity: 0.82;
  }

  .device-auth__visual {
    min-height: 100vh;
    background: var(--site-auth-visual-background);
  }

  .device-auth__mark {
    right: var(--site-auth-visual-mark-offset);
    top: 50%;
    transform: translateY(-50%) rotate(-18deg);
    color: var(--site-color-auth-visual-mark);
    font-family: var(--site-font-mono);
    font-size: var(--site-auth-visual-mark-size);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 0.85;
  }

  @media (max-width: 860px) {
    .device-auth {
      grid-template-columns: minmax(0, 1fr);
    }

    .device-auth__copy-pane {
      min-height: var(--site-auth-mobile-copy-height);
      padding: var(--site-space-7) var(--site-space-5) var(--site-space-11);
    }

    .device-auth__form {
      align-self: end;
      gap: 1.15rem;
    }

    .device-auth__form h1 {
      margin-bottom: var(--site-space-4);
      font-size: 2.15rem;
    }

    .device-auth__button {
      min-height: var(--site-auth-button-height-mobile);
    }

    .device-auth__visual {
      min-height: var(--site-auth-mobile-visual-height);
    }

    .device-auth__mark {
      right: var(--site-auth-visual-mark-mobile-offset);
      font-size: var(--site-auth-visual-mark-mobile-size);
    }
  }
</style>
