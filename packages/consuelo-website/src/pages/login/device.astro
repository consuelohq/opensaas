---
import SiteFooter from '../../components/site/SiteFooter.astro';
import SiteHeader from '../../components/site/SiteHeader.astro';
import MarketingLayout from '../../layouts/MarketingLayout.astro';

const description = 'Authorize Consuelo OS on this device.';
---

<MarketingLayout title="Authorize Consuelo OS" description={description}>
  <SiteHeader />

  <section class="launch-section device-auth">
    <div class="launch-content device-auth__content">
      <p class="device-auth__eyebrow launch-mono">Consuelo OS</p>
      <h1 class="device-auth__title launch-mono">Authorize this device</h1>
      <p class="launch-copy device-auth__copy">
        Consuelo OS is asking to connect this Mac to your workspace. Confirm the code below matches the code shown in your terminal.
      </p>

      <div class="device-auth__card">
        <span class="device-auth__label launch-mono">Device code</span>
        <strong class="device-auth__code launch-mono" data-device-code>Waiting for code</strong>
      </div>

      <p class="launch-copy device-auth__copy">
        Approve this device with your Google-backed Consuelo account, then return to your terminal to finish setup.
      </p>
      <a
        class="device-auth__button launch-mono"
        data-os-device-approve-link
        href="https://app.consuelohq.com/auth/google?action=os-device-approval"
      >
        Approve with Google
      </a>
    </div>
  </section>

  <SiteFooter />
</MarketingLayout>

<script is:inline>
  const deviceCodeNode = document.querySelector('[data-device-code]');
  const approveLink = document.querySelector('[data-os-device-approve-link]');
  const rawUserCode = new URLSearchParams(window.location.search).get('user_code') ?? '';
  const normalizedUserCode = rawUserCode.replace(/[^a-z0-9]/gi, '').toUpperCase();
  const formattedUserCode = normalizedUserCode.replace(/(.{4})(?=.)/g, '$1-');

  if (deviceCodeNode && formattedUserCode) {
    deviceCodeNode.textContent = formattedUserCode;
  }

  if (approveLink && normalizedUserCode) {
    approveLink.href = `https://app.consuelohq.com/auth/google?action=os-device-approval&osDeviceUserCode=${encodeURIComponent(normalizedUserCode)}`;
  }
</script>

<style>
  .device-auth {
    min-height: 70vh;
    display: grid;
    place-items: center;
  }

  .device-auth__content {
    max-width: 720px;
    text-align: center;
  }

  .device-auth__eyebrow {
    color: var(--color-accent, #7c3aed);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .device-auth__title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 0.9;
    margin: 1rem 0;
  }

  .device-auth__copy {
    max-width: 58ch;
    margin-left: auto;
    margin-right: auto;
  }

  .device-auth__card {
    margin: 2rem auto;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.06);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.22);
  }

  .device-auth__label {
    display: block;
    margin-bottom: 0.75rem;
    opacity: 0.72;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .device-auth__code {
    display: block;
    font-size: clamp(2rem, 8vw, 4.5rem);
    letter-spacing: 0.08em;
  }

  .device-auth__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.5rem;
    padding: 0.95rem 1.25rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.24);
    color: inherit;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: rgba(255, 255, 255, 0.12);
  }

  .device-auth__button:hover {
    background: rgba(255, 255, 255, 0.18);
  }
</style>
