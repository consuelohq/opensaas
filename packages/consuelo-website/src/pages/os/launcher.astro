---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import '../../styles/tokens.css';
import '../../styles/primitives.css';

const chatGptConnectorsUrl = 'https://chatgpt.com/apps#settings/Connectors';
const mcpUrl = 'https://os.consuelohq.com/mcp';
const siteLinks = [
  { label: 'Go to market', href: 'https://sites.consuelohq.com/gtm' },
  { label: 'Artifacts', href: 'https://sites.consuelohq.com/office' },
  { label: 'Observability', href: 'https://sites.consuelohq.com/observability' },
  { label: 'Code review', href: 'https://sites.consuelohq.com/diffs' },
];
const guideLinks = [{ label: 'Documentation', href: 'https://docs.consuelohq.com/' }];
const writingLinks = [{ label: 'Decision loops', href: '/writing/on-decision-loops' }];

const description = 'Connect ChatGPT and workspace agents to Consuelo OS.';
---

<MarketingLayout title="Consuelo OS" description={description} canonicalPath="/os/launcher/">
  <main class="os-launcher" aria-label="Consuelo OS onboarding">
    <section class="os-launcher__content">
      <div class="os-launcher__identity">Consuelo OS</div>
      <div class="os-launcher__hero">
        <h1>Welcome to Consuelo OS</h1>
        <p>
          Here is the URL to connect <a href={chatGptConnectorsUrl} target="_blank" rel="noopener noreferrer">ChatGPT</a> to your workspace.
        </p>
        <div class="os-launcher__url-row">
          <code id="mcp-url">{mcpUrl}</code>
          <button type="button" aria-label="Copy MCP URL" data-copy-target="mcp-url">Copy</button>
        </div>
        <dl class="os-launcher__meta-grid" aria-label="Consuelo OS details">
          <div><dt>Contact</dt><dd><a href="mailto:support@consuelohq.com">support@consuelohq.com</a></dd></div>
          <div><dt>Location</dt><dd>USA</dd></div>
          <div><dt>Status</dt><dd>Online</dd></div>
          <div><dt>Open position</dt><dd><a href="/careers/systems-engineer">Systems Engineer</a></dd></div>
        </dl>
      </div>
    </section>
    <aside class="os-launcher__panel" aria-label="Cloud agents and workspace links">
      <div class="os-launcher__panel-stack">
        <section>
          <h2>Connect to your cloud agents</h2>
          <p>ChatGPT is ready now.</p>
        </section>
        <section>
          <h2>Sites</h2>
          <ul>{siteLinks.map((item) => <li><a href={item.href}>{item.label}</a></li>)}</ul>
        </section>
        <section>
          <h2>Guides and Tips</h2>
          <ul>{guideLinks.map((item) => <li><a href={item.href}>{item.label}</a></li>)}</ul>
        </section>
        <section>
          <h2>Writing</h2>
          <ul>{writingLinks.map((item) => <li><a href={item.href}>{item.label}</a></li>)}</ul>
        </section>
      </div>
      <section class="os-launcher__status" aria-label="Local agents">
        <p>Connected to 0 local agents</p>
        <p>No local agents connected to workspace yet.</p>
      </section>
    </aside>
  </main>
</MarketingLayout>

<script is:inline>
  document.querySelector('[data-copy-target="mcp-url"]')?.addEventListener('click', async () => {
    const value = document.getElementById('mcp-url')?.textContent ?? '';
    try {
      await navigator.clipboard.writeText(value);
    } catch {
      document.querySelector('[data-copy-target="mcp-url"]')?.setAttribute('data-copy-status', 'failed');
    }
  });
</script>

<style>
  .os-launcher {
    min-height: 100vh;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 34vw);
    background: var(--site-color-paper);
    color: var(--site-color-ink);
  }

  .os-launcher__content {
    padding: clamp(28px, 5vw, 74px);
    display: flex;
    flex-direction: column;
    gap: clamp(52px, 10vw, 124px);
  }

  .os-launcher__identity,
  .os-launcher h2,
  .os-launcher dt,
  .os-launcher button {
    font-family: var(--site-font-mono);
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .os-launcher__identity {
    font-size: 13px;
    line-height: 1;
  }

  .os-launcher__hero {
    max-width: 760px;
    display: grid;
    gap: 24px;
  }

  .os-launcher h1 {
    margin: 0;
    font-size: clamp(44px, 7vw, 92px);
    font-weight: 500;
    line-height: 0.9;
    letter-spacing: 0;
  }

  .os-launcher p {
    margin: 0;
    font-size: clamp(18px, 1.8vw, 24px);
    line-height: 1.5;
  }

  .os-launcher a {
    color: inherit;
    text-decoration-color: color-mix(in srgb, var(--site-color-accent) 70%, transparent);
    text-underline-offset: 4px;
  }

  .os-launcher a:hover {
    color: var(--site-color-accent);
  }

  .os-launcher__url-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: stretch;
    gap: 10px;
    max-width: 820px;
  }

  .os-launcher code {
    display: flex;
    align-items: center;
    min-width: 0;
    padding: 14px 15px;
    border: 1px solid var(--site-color-line-strong);
    background: var(--site-color-surface);
    color: var(--site-color-ink);
    overflow-x: auto;
    white-space: nowrap;
    font: 13px/1.4 var(--site-font-mono);
  }

  .os-launcher button {
    border: 1px solid var(--site-color-ink);
    background: var(--site-color-ink);
    color: var(--site-color-paper);
    padding: 0 18px;
    min-width: 86px;
    cursor: pointer;
  }

  .os-launcher__meta-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px 34px;
    max-width: 760px;
  }

  .os-launcher__meta-grid div {
    display: grid;
    gap: 6px;
  }

  .os-launcher dt,
  .os-launcher h2 {
    margin: 0;
    color: var(--site-color-muted);
    font-size: 11px;
    line-height: 1.2;
  }

  .os-launcher dd,
  .os-launcher li,
  .os-launcher__panel p {
    margin: 0;
    font-size: 15px;
    line-height: 1.45;
  }

  .os-launcher__panel {
    border-left: 1px solid var(--site-color-line);
    background: var(--site-color-panel);
    padding: clamp(28px, 4vw, 58px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 52px;
  }

  .os-launcher__panel-stack {
    display: grid;
    gap: 44px;
  }

  .os-launcher__panel section {
    display: grid;
    gap: 13px;
  }

  .os-launcher ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 9px;
  }

  .os-launcher__panel a,
  .os-launcher__panel p,
  .os-launcher__status p:last-child {
    color: var(--site-color-muted);
    text-decoration: none;
  }

  .os-launcher__panel a:hover {
    color: var(--site-color-accent);
    text-decoration: underline;
  }

  @media (max-width: 860px) {
    .os-launcher {
      grid-template-columns: 1fr;
    }

    .os-launcher__panel {
      border-left: 0;
      border-top: 1px solid var(--site-color-line);
    }

    .os-launcher__url-row,
    .os-launcher__meta-grid {
      grid-template-columns: 1fr;
    }

    .os-launcher button {
      min-height: 44px;
    }
  }
</style>
