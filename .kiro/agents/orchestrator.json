  "hooks": {
    "agentSpawn": [
      {
        "command": "cd /Users/kokayi/Dev/opensaas && git log --oneline -5 && echo '---' && git status --short",
        "description": "show recent commits and working tree status"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "bash ~/.kiro/hooks/save-prompt.sh",
        "description": "save the user's prompt for the post-session reviewer"
      }
    ],
    "preToolUse": [
      {
        "command": "bash ~/.kiro/hooks/nag.sh",
        "description": "blocks every 7th tool use — forces agent to re-read spec"
      }
    ],
    "stop": [
      {
        "command": "bash ~/.kiro/hooks/review-on-stop.sh",
        "description": "spawns haiku reviewer to check spec compliance after session ends"
      }
    ]
  },
  "mcpServers": {
    "codemode": {
      "command": "node",
      "args": [
        "/Users/kokayi/Dev/kiro-codemode/dist/index.js"
      ],
      "autoApprove": [
        "execute_code"
      ]
    }
  },
  "keyboardShortcut": "ctrl+o",
  "welcomeMessage": "orchestrator online. i plan, delegate to subagents, enrich specs, review code, and ship. give me a task or point me at a linear issue."
